// SSE inline asm helpers — no immintrin.h
namespace IDK::SIMD {
    inline void add4f(const float* a, const float* b, float* r) {
        asm volatile(
            "movups (%1), %%xmm0\n\t"
            "movups (%2), %%xmm1\n\t"
            "addps  %%xmm1, %%xmm0\n\t"
            "movups %%xmm0, (%0)"
            : : "r"(r), "r"(a), "r"(b) : "xmm0", "xmm1", "memory");
    }
    inline void sub4f(const float* a, const float* b, float* r) {
        asm volatile(
            "movups (%1), %%xmm0\n\t"
            "movups (%2), %%xmm1\n\t"
            "subps  %%xmm1, %%xmm0\n\t"
            "movups %%xmm0, (%0)"
            : : "r"(r), "r"(a), "r"(b) : "xmm0", "xmm1", "memory");
    }
    inline void mul4f(const float* a, const float* b, float* r) {
        asm volatile(
            "movups (%1), %%xmm0\n\t"
            "movups (%2), %%xmm1\n\t"
            "mulps  %%xmm1, %%xmm0\n\t"
            "movups %%xmm0, (%0)"
            : : "r"(r), "r"(a), "r"(b) : "xmm0", "xmm1", "memory");
    }
    inline void scale4f(const float* a, float s, float* r) {
        asm volatile(
            "movups (%1),   %%xmm0\n\t"
            "movss  (%2),   %%xmm1\n\t"
            "shufps $0,     %%xmm1, %%xmm1\n\t"
            "mulps  %%xmm1, %%xmm0\n\t"
            "movups %%xmm0, (%0)"
            : : "r"(r), "r"(a), "r"(&s) : "xmm0", "xmm1", "memory");
    }
    inline float dot4f(const float* a, const float* b) {
        float result;
        asm volatile(
            "movups (%1),   %%xmm0\n\t"
            "movups (%2),   %%xmm1\n\t"
            "mulps  %%xmm1, %%xmm0\n\t"
            "haddps %%xmm0, %%xmm0\n\t"
            "haddps %%xmm0, %%xmm0\n\t"
            "movss  %%xmm0, (%0)"
            : : "r"(&result), "r"(a), "r"(b) : "xmm0", "xmm1", "memory");
        return result;
    }
}

namespace IDK {

// ============================================================================
//  Constants
// ============================================================================

inline constexpr float PI      = 3.14159265358979323846f;
inline constexpr float TAU     = 6.28318530717958647692f;
inline constexpr float HALF_PI = 1.57079632679489661923f;
inline constexpr float DEG2RAD = PI / 180.0f;
inline constexpr float RAD2DEG = 180.0f / PI;
inline constexpr float EPSILON = 1e-6f;

inline float toRad(float deg) { return deg * DEG2RAD; }
inline float toDeg(float rad) { return rad * RAD2DEG; }
inline float clamp(float v, float lo, float hi) { return v < lo ? lo : v > hi ? hi : v; }
inline float lerp(float a, float b, float t)    { return a + (b - a) * t; }
inline float abs_f(float v)                     { return v < 0.0f ? -v : v; }
inline float sign_f(float v)                    { return v < 0.0f ? -1.0f : v > 0.0f ? 1.0f : 0.0f; }
inline float smoothstep(float e0, float e1, float x) {
    float t = clamp((x - e0) / (e1 - e0), 0.0f, 1.0f);
    return t * t * (3.0f - 2.0f * t);
}

// ============================================================================
//  vec2
// ============================================================================

struct vec2 {
    float x, y;

    inline vec2()                    : x(0), y(0) {}
    inline vec2(float s)             : x(s), y(s) {}
    inline vec2(float x, float y)    : x(x), y(y) {}

    inline vec2 operator+(const vec2& o) const { return {x+o.x, y+o.y}; }
    inline vec2 operator-(const vec2& o) const { return {x-o.x, y-o.y}; }
    inline vec2 operator*(float s)       const { return {x*s, y*s}; }
    inline vec2 operator/(float s)       const { return {x/s, y/s}; }
    inline vec2 operator*(const vec2& o) const { return {x*o.x, y*o.y}; }
    inline vec2& operator+=(const vec2& o) { x+=o.x; y+=o.y; return *this; }
    inline vec2& operator-=(const vec2& o) { x-=o.x; y-=o.y; return *this; }
    inline vec2& operator*=(float s)       { x*=s;   y*=s;   return *this; }
    inline vec2& operator/=(float s)       { x/=s;   y/=s;   return *this; }
    inline bool  operator==(const vec2& o) const { return x==o.x && y==o.y; }
    inline bool  operator!=(const vec2& o) const { return !(*this==o); }
    inline float operator[](int i) const { return i==0?x:y; }
    inline float& operator[](int i)      { return i==0?x:y; }
    inline vec2 operator-() const { return {-x, -y}; }

    inline float dot(const vec2& o)  const { return x*o.x + y*o.y; }
    inline float cross(const vec2& o) const { return x*o.y - y*o.x; }
    inline float length2()           const { return x*x + y*y; }
    inline float length()            const { return asm_sqrtf(length2()); }
    inline vec2  normalize()         const { float l = length(); return l > EPSILON ? (*this / l) : vec2(0); }
    inline vec2  perp()              const { return {-y, x}; }
    inline vec2  reflect(const vec2& n) const { return *this - n * (2.0f * dot(n)); }
    inline vec2  lerp(const vec2& b, float t) const { return *this + (b - *this) * t; }
    inline vec2  abs() const { return {abs_f(x), abs_f(y)}; }
    inline float angle() const { return asm_atan2f(y, x); }

    // Swizzle
    inline vec2 xx() const { return {x,x}; }
    inline vec2 yy() const { return {y,y}; }
    inline vec2 yx() const { return {y,x}; }
};

inline vec2 operator*(float s, const vec2& v) { return v * s; }
inline float dot(const vec2& a, const vec2& b) { return a.dot(b); }
inline float length(const vec2& v) { return v.length(); }
inline vec2  normalize(const vec2& v) { return v.normalize(); }

// ============================================================================
//  vec3
// ============================================================================

struct vec4; // forward

struct vec3 {
    float x, y, z;

    inline vec3()                         : x(0), y(0), z(0) {}
    inline vec3(float s)                  : x(s), y(s), z(s) {}
    inline vec3(float x, float y, float z): x(x), y(y), z(z) {}
    inline vec3(const vec2& v, float z)   : x(v.x), y(v.y), z(z) {}

    inline vec3 operator+(const vec3& o) const { return {x+o.x, y+o.y, z+o.z}; }
    inline vec3 operator-(const vec3& o) const { return {x-o.x, y-o.y, z-o.z}; }
    inline vec3 operator*(float s)       const { return {x*s, y*s, z*s}; }
    inline vec3 operator/(float s)       const { return {x/s, y/s, z/s}; }
    inline vec3 operator*(const vec3& o) const { return {x*o.x, y*o.y, z*o.z}; }
    inline vec3& operator+=(const vec3& o) { x+=o.x; y+=o.y; z+=o.z; return *this; }
    inline vec3& operator-=(const vec3& o) { x-=o.x; y-=o.y; z-=o.z; return *this; }
    inline vec3& operator*=(float s)       { x*=s; y*=s; z*=s; return *this; }
    inline vec3& operator/=(float s)       { x/=s; y/=s; z/=s; return *this; }
    inline bool  operator==(const vec3& o) const { return x==o.x && y==o.y && z==o.z; }
    inline bool  operator!=(const vec3& o) const { return !(*this==o); }
    inline float operator[](int i) const { return i==0?x:i==1?y:z; }
    inline float& operator[](int i)      { return i==0?x:i==1?y:z; }
    inline vec3 operator-() const { return {-x, -y, -z}; }

    inline float dot(const vec3& o)   const { return x*o.x + y*o.y + z*o.z; }
    inline vec3  cross(const vec3& o) const {
        return { y*o.z - z*o.y, z*o.x - x*o.z, x*o.y - y*o.x };
    }
    inline float length2() const { return x*x + y*y + z*z; }
    inline float length()  const { return asm_sqrtf(length2()); }
    inline vec3  normalize() const { float l = length(); return l > EPSILON ? (*this / l) : vec3(0); }
    inline vec3  reflect(const vec3& n)  const { return *this - n * (2.0f * dot(n)); }
    inline vec3  refract(const vec3& n, float eta) const {
        float d = dot(n); float k = 1.0f - eta*eta*(1.0f - d*d);
        return k < 0.0f ? vec3(0) : *this * eta - n * (eta * d + asm_sqrtf(k));
    }
    inline vec3  lerp(const vec3& b, float t) const { return *this + (b - *this) * t; }
    inline vec3  abs() const { return {abs_f(x), abs_f(y), abs_f(z)}; }
    inline float angle(const vec3& o) const { return asm_acosf(clamp(dot(o) / (length()*o.length()), -1.0f, 1.0f)); }

    // Swizzle
    inline vec2 xy()  const { return {x,y}; }
    inline vec2 xz()  const { return {x,z}; }
    inline vec2 yz()  const { return {y,z}; }
    inline vec3 xyz() const { return *this; }
    inline vec3 xzy() const { return {x,z,y}; }
    inline vec3 yxz() const { return {y,x,z}; }
    inline vec3 zyx() const { return {z,y,x}; }
    inline vec3 xxx() const { return {x,x,x}; }
    inline vec3 yyy() const { return {y,y,y}; }
    inline vec3 zzz() const { return {z,z,z}; }

    // Common directions
    static inline vec3 UP()      { return {0,1,0}; }
    static inline vec3 DOWN()    { return {0,-1,0}; }
    static inline vec3 RIGHT()   { return {1,0,0}; }
    static inline vec3 LEFT()    { return {-1,0,0}; }
    static inline vec3 FORWARD() { return {0,0,-1}; }
    static inline vec3 BACK()    { return {0,0,1}; }
};

inline vec3 operator*(float s, const vec3& v) { return v * s; }
inline float dot(const vec3& a, const vec3& b)   { return a.dot(b); }
inline vec3  cross(const vec3& a, const vec3& b) { return a.cross(b); }
inline float length(const vec3& v) { return v.length(); }
inline vec3  normalize(const vec3& v) { return v.normalize(); }
inline vec3  lerp(const vec3& a, const vec3& b, float t) { return a.lerp(b, t); }

// ============================================================================
//  vec4
// ============================================================================

struct alignas(16) vec4 {
    float x, y, z, w;

    inline vec4()                                : x(0), y(0), z(0), w(0) {}
    inline vec4(float s)                         : x(s), y(s), z(s), w(s) {}
    inline vec4(float x, float y, float z, float w) : x(x), y(y), z(z), w(w) {}
    inline vec4(const vec3& v, float w)          : x(v.x), y(v.y), z(v.z), w(w) {}
    inline vec4(const vec2& a, const vec2& b)    : x(a.x), y(a.y), z(b.x), w(b.y) {}

    inline vec4 operator+(const vec4& o) const {
        vec4 r; SIMD::add4f(&x, &o.x, &r.x); return r;
    }
    inline vec4 operator-(const vec4& o) const {
        vec4 r; SIMD::sub4f(&x, &o.x, &r.x); return r;
    }
    inline vec4 operator*(float s) const {
        vec4 r; SIMD::scale4f(&x, s, &r.x); return r;
    }
    inline vec4 operator/(float s) const { return *this * (1.0f/s); }
    inline vec4 operator*(const vec4& o) const {
        vec4 r; SIMD::mul4f(&x, &o.x, &r.x); return r;
    }
    inline vec4& operator+=(const vec4& o) { *this = *this + o; return *this; }
    inline vec4& operator-=(const vec4& o) { *this = *this - o; return *this; }
    inline vec4& operator*=(float s)       { *this = *this * s; return *this; }
    inline vec4& operator/=(float s)       { *this = *this / s; return *this; }
    inline bool  operator==(const vec4& o) const { return x==o.x&&y==o.y&&z==o.z&&w==o.w; }
    inline bool  operator!=(const vec4& o) const { return !(*this==o); }
    inline float operator[](int i) const { return (&x)[i]; }
    inline float& operator[](int i)      { return (&x)[i]; }
    inline vec4 operator-() const { return {-x,-y,-z,-w}; }

    inline float dot(const vec4& o) const { return SIMD::dot4f(&x, &o.x); }
    inline float length2()  const { return dot(*this); }
    inline float length()   const { return asm_sqrtf(length2()); }
    inline vec4  normalize() const { float l = length(); return l > EPSILON ? *this / l : vec4(0); }
    inline vec4  lerp(const vec4& b, float t) const { return *this + (b - *this) * t; }

    // Swizzle
    inline vec2 xy()  const { return {x,y}; }
    inline vec2 zw()  const { return {z,w}; }
    inline vec3 xyz() const { return {x,y,z}; }
    inline vec3 rgb() const { return {x,y,z}; }
    inline float r()  const { return x; }
    inline float g()  const { return y; }
    inline float b()  const { return z; }
    inline float a()  const { return w; }
};

inline vec4 operator*(float s, const vec4& v) { return v * s; }
inline float dot(const vec4& a, const vec4& b) { return a.dot(b); }
inline vec4  normalize(const vec4& v) { return v.normalize(); }
inline vec4  lerp(const vec4& a, const vec4& b, float t) { return a.lerp(b, t); }

// ============================================================================
//  mat4  (column-major, Vulkan-compatible)
// ============================================================================

struct alignas(16) mat4 {
    float m[4][4]; // m[col][row]

    inline mat4() {
        for (int i = 0; i < 4; ++i)
            for (int j = 0; j < 4; ++j)
                m[i][j] = (i == j) ? 1.0f : 0.0f;
    }

    inline mat4(float d) {
        for (int i = 0; i < 4; ++i)
            for (int j = 0; j < 4; ++j)
                m[i][j] = (i == j) ? d : 0.0f;
    }

    inline mat4(
        float m00, float m01, float m02, float m03,
        float m10, float m11, float m12, float m13,
        float m20, float m21, float m22, float m23,
        float m30, float m31, float m32, float m33) {
        m[0][0]=m00; m[0][1]=m01; m[0][2]=m02; m[0][3]=m03;
        m[1][0]=m10; m[1][1]=m11; m[1][2]=m12; m[1][3]=m13;
        m[2][0]=m20; m[2][1]=m21; m[2][2]=m22; m[2][3]=m23;
        m[3][0]=m30; m[3][1]=m31; m[3][2]=m32; m[3][3]=m33;
    }

    static inline mat4 identity() { return mat4(1.0f); }
    static inline mat4 zero()     { return mat4(0.0f); }

    inline const float* data() const { return &m[0][0]; }

    inline vec4 col(int i) const { return {m[i][0], m[i][1], m[i][2], m[i][3]}; }
    inline vec4 row(int i) const { return {m[0][i], m[1][i], m[2][i], m[3][i]}; }

    inline mat4 operator*(const mat4& o) const {
        mat4 res(0.0f);
        for (int c = 0; c < 4; ++c)
            for (int r = 0; r < 4; ++r)
                for (int k = 0; k < 4; ++k)
                    res.m[c][r] += m[k][r] * o.m[c][k];
        return res;
    }

    inline vec4 operator*(const vec4& v) const {
        return {
            m[0][0]*v.x + m[1][0]*v.y + m[2][0]*v.z + m[3][0]*v.w,
            m[0][1]*v.x + m[1][1]*v.y + m[2][1]*v.z + m[3][1]*v.w,
            m[0][2]*v.x + m[1][2]*v.y + m[2][2]*v.z + m[3][2]*v.w,
            m[0][3]*v.x + m[1][3]*v.y + m[2][3]*v.z + m[3][3]*v.w,
        };
    }

    inline vec3 transformPoint(const vec3& v) const {
        vec4 r = *this * vec4(v, 1.0f);
        return r.xyz() / r.w;
    }

    inline vec3 transformDir(const vec3& v) const {
        return (*this * vec4(v, 0.0f)).xyz();
    }

    inline mat4 operator+(const mat4& o) const {
        mat4 r(0.0f);
        for (int i = 0; i < 4; ++i)
            for (int j = 0; j < 4; ++j)
                r.m[i][j] = m[i][j] + o.m[i][j];
        return r;
    }

    inline mat4 operator*(float s) const {
        mat4 r(0.0f);
        for (int i = 0; i < 4; ++i)
            for (int j = 0; j < 4; ++j)
                r.m[i][j] = m[i][j] * s;
        return r;
    }

    inline mat4 transpose() const {
        mat4 r(0.0f);
        for (int i = 0; i < 4; ++i)
            for (int j = 0; j < 4; ++j)
                r.m[i][j] = m[j][i];
        return r;
    }

    inline mat4 inverse() const {
        float s0 = m[0][0]*m[1][1] - m[1][0]*m[0][1];
        float s1 = m[0][0]*m[2][1] - m[2][0]*m[0][1];
        float s2 = m[0][0]*m[3][1] - m[3][0]*m[0][1];
        float s3 = m[1][0]*m[2][1] - m[2][0]*m[1][1];
        float s4 = m[1][0]*m[3][1] - m[3][0]*m[1][1];
        float s5 = m[2][0]*m[3][1] - m[3][0]*m[2][1];
        float c5 = m[2][2]*m[3][3] - m[3][2]*m[2][3];
        float c4 = m[1][2]*m[3][3] - m[3][2]*m[1][3];
        float c3 = m[1][2]*m[2][3] - m[2][2]*m[1][3];
        float c2 = m[0][2]*m[3][3] - m[3][2]*m[0][3];
        float c1 = m[0][2]*m[2][3] - m[2][2]*m[0][3];
        float c0 = m[0][2]*m[1][3] - m[1][2]*m[0][3];

        float det = s0*c5 - s1*c4 + s2*c3 + s3*c2 - s4*c1 + s5*c0;
        if (abs_f(det) < EPSILON) return mat4(1.0f);
        float inv = 1.0f / det;

        mat4 r(0.0f);
        r.m[0][0] = ( m[1][1]*c5 - m[2][1]*c4 + m[3][1]*c3) * inv;
        r.m[0][1] = (-m[0][1]*c5 + m[2][1]*c2 - m[3][1]*c1) * inv;
        r.m[0][2] = ( m[0][1]*c4 - m[1][1]*c2 + m[3][1]*c0) * inv;
        r.m[0][3] = (-m[0][1]*c3 + m[1][1]*c1 - m[2][1]*c0) * inv;
        r.m[1][0] = (-m[1][0]*c5 + m[2][0]*c4 - m[3][0]*c3) * inv;
        r.m[1][1] = ( m[0][0]*c5 - m[2][0]*c2 + m[3][0]*c1) * inv;
        r.m[1][2] = (-m[0][0]*c4 + m[1][0]*c2 - m[3][0]*c0) * inv;
        r.m[1][3] = ( m[0][0]*c3 - m[1][0]*c1 + m[2][0]*c0) * inv;
        r.m[2][0] = ( m[1][0]*s5 - m[2][0]*s4 + m[3][0]*s3) * inv;
        r.m[2][1] = (-m[0][0]*s5 + m[2][0]*s2 - m[3][0]*s1) * inv;
        r.m[2][2] = ( m[0][0]*s4 - m[1][0]*s2 + m[3][0]*s0) * inv;
        r.m[2][3] = (-m[0][0]*s3 + m[1][0]*s1 - m[2][0]*s0) * inv;
        r.m[3][0] = (-m[1][1]*s5 + m[2][1]*s4 - m[3][1]*s3) * inv;
        r.m[3][1] = ( m[0][1]*s5 - m[2][1]*s2 + m[3][1]*s1) * inv;
        r.m[3][2] = (-m[0][1]*s4 + m[1][1]*s2 - m[3][1]*s0) * inv;
        r.m[3][3] = ( m[0][1]*s3 - m[1][1]*s1 + m[2][1]*s0) * inv;
        return r;
    }

    inline float determinant() const {
        float s0 = m[0][0]*m[1][1] - m[1][0]*m[0][1];
        float s1 = m[0][0]*m[2][1] - m[2][0]*m[0][1];
        float s2 = m[0][0]*m[3][1] - m[3][0]*m[0][1];
        float s3 = m[1][0]*m[2][1] - m[2][0]*m[1][1];
        float s4 = m[1][0]*m[3][1] - m[3][0]*m[1][1];
        float s5 = m[2][0]*m[3][1] - m[3][0]*m[2][1];
        float c5 = m[2][2]*m[3][3] - m[3][2]*m[2][3];
        float c4 = m[1][2]*m[3][3] - m[3][2]*m[1][3];
        float c3 = m[1][2]*m[2][3] - m[2][2]*m[1][3];
        float c2 = m[0][2]*m[3][3] - m[3][2]*m[0][3];
        float c1 = m[0][2]*m[2][3] - m[2][2]*m[0][3];
        float c0 = m[0][2]*m[1][3] - m[1][2]*m[0][3];
        return s0*c5 - s1*c4 + s2*c3 + s3*c2 - s4*c1 + s5*c0;
    }
};

// ============================================================================
//  mat3
// ============================================================================

struct mat3 {
    float m[3][3];

    inline mat3() {
        for (int i=0;i<3;++i) for (int j=0;j<3;++j) m[i][j]=(i==j)?1.0f:0.0f;
    }
    inline mat3(float d) {
        for (int i=0;i<3;++i) for (int j=0;j<3;++j) m[i][j]=(i==j)?d:0.0f;
    }
    inline mat3(const mat4& M) {
        for (int i=0;i<3;++i) for (int j=0;j<3;++j) m[i][j]=M.m[i][j];
    }

    inline mat3 operator*(const mat3& o) const {
        mat3 r(0.0f);
        for (int c=0;c<3;++c)
            for (int r2=0;r2<3;++r2)
                for (int k=0;k<3;++k)
                    r.m[c][r2] += m[k][r2] * o.m[c][k];
        return r;
    }
    inline vec3 operator*(const vec3& v) const {
        return {
            m[0][0]*v.x + m[1][0]*v.y + m[2][0]*v.z,
            m[0][1]*v.x + m[1][1]*v.y + m[2][1]*v.z,
            m[0][2]*v.x + m[1][2]*v.y + m[2][2]*v.z,
        };
    }
    inline mat3 transpose() const {
        mat3 r(0.0f);
        for (int i=0;i<3;++i) for (int j=0;j<3;++j) r.m[i][j]=m[j][i];
        return r;
    }
    inline mat3 inverse() const {
        float det =
            m[0][0]*(m[1][1]*m[2][2]-m[2][1]*m[1][2]) -
            m[1][0]*(m[0][1]*m[2][2]-m[2][1]*m[0][2]) +
            m[2][0]*(m[0][1]*m[1][2]-m[1][1]*m[0][2]);
        if (abs_f(det) < EPSILON) return mat3(1.0f);
        float inv = 1.0f / det;
        mat3 r(0.0f);
        r.m[0][0] = (m[1][1]*m[2][2]-m[2][1]*m[1][2])*inv;
        r.m[1][0] =-(m[1][0]*m[2][2]-m[2][0]*m[1][2])*inv;
        r.m[2][0] = (m[1][0]*m[2][1]-m[2][0]*m[1][1])*inv;
        r.m[0][1] =-(m[0][1]*m[2][2]-m[2][1]*m[0][2])*inv;
        r.m[1][1] = (m[0][0]*m[2][2]-m[2][0]*m[0][2])*inv;
        r.m[2][1] =-(m[0][0]*m[2][1]-m[2][0]*m[0][1])*inv;
        r.m[0][2] = (m[0][1]*m[1][2]-m[1][1]*m[0][2])*inv;
        r.m[1][2] =-(m[0][0]*m[1][2]-m[1][0]*m[0][2])*inv;
        r.m[2][2] = (m[0][0]*m[1][1]-m[1][0]*m[0][1])*inv;
        return r;
    }
    // Normal matrix (inverse transpose)
    inline mat3 normalMatrix() const { return inverse().transpose(); }
};

// ============================================================================
//  Quaternion
// ============================================================================

struct quat {
    float x, y, z, w; // w = scalar part

    inline quat()                                    : x(0), y(0), z(0), w(1) {}
    inline quat(float x, float y, float z, float w) : x(x), y(y), z(z), w(w) {}
    inline quat(const vec3& axis, float angle) {
        float s = asm_sinf(angle * 0.5f);
        vec3 a = axis.normalize();
        x = a.x * s; y = a.y * s; z = a.z * s; w = asm_cosf(angle * 0.5f);
    }

    static inline quat identity() { return {0,0,0,1}; }

    inline quat operator*(const quat& o) const {
        return {
            w*o.x + x*o.w + y*o.z - z*o.y,
            w*o.y - x*o.z + y*o.w + z*o.x,
            w*o.z + x*o.y - y*o.x + z*o.w,
            w*o.w - x*o.x - y*o.y - z*o.z
        };
    }
    inline quat operator+(const quat& o) const { return {x+o.x, y+o.y, z+o.z, w+o.w}; }
    inline quat operator*(float s)       const { return {x*s, y*s, z*s, w*s}; }
    inline quat& operator*=(const quat& o) { *this = *this * o; return *this; }
    inline bool  operator==(const quat& o) const { return x==o.x&&y==o.y&&z==o.z&&w==o.w; }

    inline float dot(const quat& o)  const { return x*o.x+y*o.y+z*o.z+w*o.w; }
    inline float length2()           const { return x*x+y*y+z*z+w*w; }
    inline float length()            const { return asm_sqrtf(length2()); }
    inline quat  normalize()         const { float l=length(); return l>EPSILON?*this*(1.0f/l):identity(); }
    inline quat  conjugate()         const { return {-x,-y,-z,w}; }
    inline quat  inverse()           const { float l2=length2(); return l2>EPSILON?conjugate()*(1.0f/l2):identity(); }

    inline vec3 rotate(const vec3& v) const {
        // Optimized Rodrigues rotation via quat
        vec3 qv = {x,y,z};
        vec3 t  = cross(qv, v) * 2.0f;
        return v + t * w + cross(qv, t);
    }

    inline mat4 toMat4() const {
        float xx=x*x, yy=y*y, zz=z*z;
        float xy=x*y, xz=x*z, yz=y*z;
        float wx=w*x, wy=w*y, wz=w*z;
        return {
            1-2*(yy+zz), 2*(xy+wz),   2*(xz-wy),   0,
            2*(xy-wz),   1-2*(xx+zz), 2*(yz+wx),   0,
            2*(xz+wy),   2*(yz-wx),   1-2*(xx+yy), 0,
            0,           0,           0,            1
        };
    }

    inline mat3 toMat3() const { return mat3(toMat4()); }

    inline void toAxisAngle(vec3& axis, float& angle) const {
        quat q = normalize();
        angle = 2.0f * asm_acosf(clamp(q.w, -1.0f, 1.0f));
        float s = asm_sqrtf(1.0f - q.w*q.w);
        if (s < EPSILON) axis = {1,0,0};
        else axis = {q.x/s, q.y/s, q.z/s};
    }

    inline vec3 eulerAngles() const {
        float sinr_cosp = 2.0f*(w*x + y*z);
        float cosr_cosp = 1.0f - 2.0f*(x*x + y*y);
        float pitch = asm_atan2f(sinr_cosp, cosr_cosp);
        float sinp = 2.0f*(w*y - z*x);
        float yaw = abs_f(sinp) >= 1.0f ? asm_copysignf(HALF_PI, sinp) : asinf(sinp);
        float siny_cosp = 2.0f*(w*z + x*y);
        float cosy_cosp = 1.0f - 2.0f*(y*y + z*z);
        float roll = asm_atan2f(siny_cosp, cosy_cosp);
        return {pitch, yaw, roll};
    }

    static inline quat fromEuler(float pitch, float yaw, float roll) {
        float cp=asm_cosf(pitch*.5f), sp=asm_sinf(pitch*.5f);
        float cy=asm_cosf(yaw*.5f),   sy=asm_sinf(yaw*.5f);
        float cr=asm_cosf(roll*.5f),  sr=asm_sinf(roll*.5f);
        return {
            sr*cp*cy - cr*sp*sy,
            cr*sp*cy + sr*cp*sy,
            cr*cp*sy - sr*sp*cy,
            cr*cp*cy + sr*sp*sy
        };
    }

    static inline quat fromEuler(const vec3& e) { return fromEuler(e.x, e.y, e.z); }

    static inline quat fromMat4(const mat4& M) {
        float trace = M.m[0][0] + M.m[1][1] + M.m[2][2];
        quat q;
        if (trace > 0) {
            float s = 0.5f / asm_sqrtf(trace + 1.0f);
            q.w = 0.25f / s;
            q.x = (M.m[1][2] - M.m[2][1]) * s;
            q.y = (M.m[2][0] - M.m[0][2]) * s;
            q.z = (M.m[0][1] - M.m[1][0]) * s;
        } else if (M.m[0][0] > M.m[1][1] && M.m[0][0] > M.m[2][2]) {
            float s = 2.0f * asm_sqrtf(1.0f + M.m[0][0] - M.m[1][1] - M.m[2][2]);
            q.w = (M.m[1][2] - M.m[2][1]) / s;
            q.x = 0.25f * s;
            q.y = (M.m[0][1] + M.m[1][0]) / s;
            q.z = (M.m[2][0] + M.m[0][2]) / s;
        } else if (M.m[1][1] > M.m[2][2]) {
            float s = 2.0f * asm_sqrtf(1.0f + M.m[1][1] - M.m[0][0] - M.m[2][2]);
            q.w = (M.m[2][0] - M.m[0][2]) / s;
            q.x = (M.m[0][1] + M.m[1][0]) / s;
            q.y = 0.25f * s;
            q.z = (M.m[1][2] + M.m[2][1]) / s;
        } else {
            float s = 2.0f * asm_sqrtf(1.0f + M.m[2][2] - M.m[0][0] - M.m[1][1]);
            q.w = (M.m[0][1] - M.m[1][0]) / s;
            q.x = (M.m[2][0] + M.m[0][2]) / s;
            q.y = (M.m[1][2] + M.m[2][1]) / s;
            q.z = 0.25f * s;
        }
        return q.normalize();
    }

    // Spherical linear interpolation
    static inline quat slerp(const quat& a, const quat& b, float t) {
        quat bb = b;
        float d = a.dot(b);
        if (d < 0.0f) { bb = bb * -1.0f; d = -d; }
        if (d > 0.9995f) return (a + (bb - a) * t).normalize();
        float theta0 = asm_acosf(d);
        float theta  = theta0 * t;
        float s0 = asm_cosf(theta) - d * asm_sinf(theta) / asm_sinf(theta0);
        float s1 = asm_sinf(theta) / asm_sinf(theta0);
        return (a * s0 + bb * s1).normalize();
    }

    // Squad (smooth quat interpolation for paths)
    static inline quat squad(const quat& q0, const quat& q1, const quat& q2, const quat& q3, float t) {
        return slerp(slerp(q1, q2, t), slerp(q0, q3, t), 2.0f * t * (1.0f - t));
    }

    inline quat operator-(const quat& o) const { return {x-o.x, y-o.y, z-o.z, w-o.w}; }
};

inline quat normalize(const quat& q) { return q.normalize(); }
inline quat slerp(const quat& a, const quat& b, float t) { return quat::slerp(a, b, t); }

// ============================================================================
//  Transform functions
// ============================================================================

inline mat4 translate(const vec3& v) {
    mat4 r;
    r.m[3][0] = v.x; r.m[3][1] = v.y; r.m[3][2] = v.z;
    return r;
}

inline mat4 scale(const vec3& v) {
    mat4 r;
    r.m[0][0] = v.x; r.m[1][1] = v.y; r.m[2][2] = v.z;
    return r;
}

inline mat4 scale(float s) { return scale({s, s, s}); }

inline mat4 rotate(float angle, const vec3& axis) {
    return quat(axis, angle).toMat4();
}

inline mat4 rotateX(float angle) { return rotate(angle, {1,0,0}); }
inline mat4 rotateY(float angle) { return rotate(angle, {0,1,0}); }
inline mat4 rotateZ(float angle) { return rotate(angle, {0,0,1}); }

// TRS — compose transform, rotate, scale into one matrix
inline mat4 TRS(const vec3& t, const quat& r, const vec3& s) {
    return translate(t) * r.toMat4() * scale(s);
}

// View matrix (right-handed, -Z forward — Vulkan/OpenGL compatible)
inline mat4 lookAt(const vec3& eye, const vec3& center, const vec3& up) {
    vec3 f = (center - eye).normalize();
    vec3 r = cross(f, up).normalize();
    vec3 u = cross(r, f);
    mat4 m;
    m.m[0][0]= r.x; m.m[1][0]= r.y; m.m[2][0]= r.z; m.m[3][0]=-dot(r, eye);
    m.m[0][1]= u.x; m.m[1][1]= u.y; m.m[2][1]= u.z; m.m[3][1]=-dot(u, eye);
    m.m[0][2]=-f.x; m.m[1][2]=-f.y; m.m[2][2]=-f.z; m.m[3][2]= dot(f, eye);
    m.m[0][3]= 0;   m.m[1][3]= 0;   m.m[2][3]= 0;   m.m[3][3]= 1;
    return m;
}

// Perspective projection — Vulkan NDC (depth 0..1, Y flipped)
inline mat4 perspective(float fovY, float aspect, float zNear, float zFar) {
    float tanHalf = asm_tanf(fovY * 0.5f);
    mat4 r(0.0f);
    r.m[0][0] =  1.0f / (aspect * tanHalf);
    r.m[1][1] = -1.0f / tanHalf;             // Vulkan: flip Y
    r.m[2][2] =  zFar / (zNear - zFar);
    r.m[2][3] = -1.0f;
    r.m[3][2] = -(zFar * zNear) / (zFar - zNear);
    return r;
}

// Perspective projection — OpenGL NDC (depth -1..1)
inline mat4 perspectiveGL(float fovY, float aspect, float zNear, float zFar) {
    float tanHalf = asm_tanf(fovY * 0.5f);
    mat4 r(0.0f);
    r.m[0][0] =  1.0f / (aspect * tanHalf);
    r.m[1][1] =  1.0f / tanHalf;
    r.m[2][2] = -(zFar + zNear) / (zFar - zNear);
    r.m[2][3] = -1.0f;
    r.m[3][2] = -(2.0f * zFar * zNear) / (zFar - zNear);
    return r;
}

// Orthographic projection — Vulkan
inline mat4 ortho(float left, float right, float bottom, float top, float zNear, float zFar) {
    mat4 r;
    r.m[0][0] =  2.0f / (right - left);
    r.m[1][1] = -2.0f / (top - bottom);  // Vulkan: flip Y
    r.m[2][2] = -1.0f / (zFar - zNear);
    r.m[3][0] = -(right + left) / (right - left);
    r.m[3][1] =  (top + bottom) / (top - bottom);
    r.m[3][2] = -zNear / (zFar - zNear);
    return r;
}

// Orthographic projection — OpenGL
inline mat4 orthoGL(float left, float right, float bottom, float top, float zNear, float zFar) {
    mat4 r;
    r.m[0][0] =  2.0f / (right - left);
    r.m[1][1] =  2.0f / (top - bottom);
    r.m[2][2] = -2.0f / (zFar - zNear);
    r.m[3][0] = -(right + left) / (right - left);
    r.m[3][1] = -(top + bottom) / (top - bottom);
    r.m[3][2] = -(zFar + zNear) / (zFar - zNear);
    return r;
}

// Infinite perspective (useful for shadow maps)
inline mat4 infinitePerspective(float fovY, float aspect, float zNear) {
    float range = asm_tanf(fovY * 0.5f) * zNear;
    mat4 r(0.0f);
    r.m[0][0] = (2.0f * zNear) / (range * aspect * 2.0f);
    r.m[1][1] = zNear / range;
    r.m[2][2] = -1.0f;
    r.m[2][3] = -1.0f;
    r.m[3][2] = -2.0f * zNear;
    return r;
}

// Unproject: screen coords → world space
inline vec3 unproject(const vec3& win, const mat4& model, const mat4& proj, const vec4& viewport) {
    mat4 inv = (proj * model).inverse();
    vec4 tmp = {
        (win.x - viewport.x) / viewport.z * 2.0f - 1.0f,
        (win.y - viewport.y) / viewport.w * 2.0f - 1.0f,
        win.z * 2.0f - 1.0f,
        1.0f
    };
    vec4 obj = inv * tmp;
    return obj.xyz() / obj.w;
}

// ============================================================================
//  Color helpers
// ============================================================================

namespace Color {

    inline vec4 fromHex(uint32_t hex) {
        return {
            ((hex >> 16) & 0xFF) / 255.0f,
            ((hex >>  8) & 0xFF) / 255.0f,
            ((hex >>  0) & 0xFF) / 255.0f,
            ((hex >> 24) & 0xFF) / 255.0f
        };
    }

    inline uint32_t toHex(const vec4& c) {
        uint32_t r = (uint32_t)(clamp(c.x, 0.0f, 1.0f) * 255);
        uint32_t g = (uint32_t)(clamp(c.y, 0.0f, 1.0f) * 255);
        uint32_t b = (uint32_t)(clamp(c.z, 0.0f, 1.0f) * 255);
        uint32_t a = (uint32_t)(clamp(c.w, 0.0f, 1.0f) * 255);
        return (a << 24) | (r << 16) | (g << 8) | b;
    }

    // HSV (h: 0-360, s/v: 0-1) → RGB
    inline vec3 hsvToRgb(float h, float s, float v) {
        if (s <= 0.0f) return {v, v, v};
        float hh = h / 60.0f;
        int   i  = (int)hh;
        float ff = hh - i;
        float p  = v * (1.0f - s);
        float q  = v * (1.0f - s * ff);
        float t  = v * (1.0f - s * (1.0f - ff));
        switch (i % 6) {
            case 0: return {v, t, p};
            case 1: return {q, v, p};
            case 2: return {p, v, t};
            case 3: return {p, q, v};
            case 4: return {t, p, v};
            default: return {v, p, q};
        }
    }

    // RGB → HSV
    inline vec3 rgbToHsv(float r, float g, float b) {
        float mx = r > g ? (r > b ? r : b) : (g > b ? g : b);
        float mn = r < g ? (r < b ? r : b) : (g < b ? g : b);
        float d  = mx - mn;
        float h  = 0, s = mx > EPSILON ? d / mx : 0, v = mx;
        if (d > EPSILON) {
            if      (mx == r) h = 60.0f * asm_fmodf((g - b) / d, 6.0f);
            else if (mx == g) h = 60.0f * ((b - r) / d + 2.0f);
            else              h = 60.0f * ((r - g) / d + 4.0f);
            if (h < 0) h += 360.0f;
        }
        return {h, s, v};
    }

    // Linear → sRGB gamma
    inline float linearToSrgb(float c) {
        return c <= 0.0031308f ? 12.92f * c : 1.055f * asm_powf(c, 1.0f/2.4f) - 0.055f;
    }

    // sRGB → linear
    inline float srgbToLinear(float c) {
        return c <= 0.04045f ? c / 12.92f : asm_powf((c + 0.055f) / 1.055f, 2.4f);
    }

    inline vec3 linearToSrgb(const vec3& c) {
        return {linearToSrgb(c.x), linearToSrgb(c.y), linearToSrgb(c.z)};
    }

    inline vec3 srgbToLinear(const vec3& c) {
        return {srgbToLinear(c.x), srgbToLinear(c.y), srgbToLinear(c.z)};
    }

    // Luminance (perceptual)
    inline float luminance(const vec3& c) { return 0.2126f*c.x + 0.7152f*c.y + 0.0722f*c.z; }

    inline vec4 WHITE  = {1,1,1,1};
    inline vec4 BLACK  = {0,0,0,1};
    inline vec4 RED    = {1,0,0,1};
    inline vec4 GREEN  = {0,1,0,1};
    inline vec4 BLUE   = {0,0,1,1};
    inline vec4 YELLOW = {1,1,0,1};
    inline vec4 CYAN   = {0,1,1,1};
    inline vec4 MAGENTA= {1,0,1,1};
    inline vec4 TRANSPARENT = {0,0,0,0};
}

// ============================================================================
//  AABB (Axis-aligned bounding box)
// ============================================================================

struct AABB {
    vec3 min, max;

    inline AABB() : min(1e30f), max(-1e30f) {}
    inline AABB(const vec3& min, const vec3& max) : min(min), max(max) {}

    inline vec3  center()  const { return (min + max) * 0.5f; }
    inline vec3  extents() const { return (max - min) * 0.5f; }
    inline vec3  size()    const { return max - min; }
    inline float volume()  const { vec3 s = size(); return s.x*s.y*s.z; }

    inline bool contains(const vec3& p) const {
        return p.x>=min.x && p.x<=max.x && p.y>=min.y && p.y<=max.y && p.z>=min.z && p.z<=max.z;
    }
    inline bool intersects(const AABB& o) const {
        return min.x<=o.max.x && max.x>=o.min.x &&
               min.y<=o.max.y && max.y>=o.min.y &&
               min.z<=o.max.z && max.z>=o.min.z;
    }
    inline AABB merge(const AABB& o) const {
        return {
            {min.x<o.min.x?min.x:o.min.x, min.y<o.min.y?min.y:o.min.y, min.z<o.min.z?min.z:o.min.z},
            {max.x>o.max.x?max.x:o.max.x, max.y>o.max.y?max.y:o.max.y, max.z>o.max.z?max.z:o.max.z}
        };
    }
    inline void expand(const vec3& p) {
        if (p.x<min.x) min.x=p.x; if (p.x>max.x) max.x=p.x;
        if (p.y<min.y) min.y=p.y; if (p.y>max.y) max.y=p.y;
        if (p.z<min.z) min.z=p.z; if (p.z>max.z) max.z=p.z;
    }
    // Ray-AABB intersection (returns t or -1)
    inline float rayIntersect(const vec3& origin, const vec3& dir) const {
        vec3 inv = {1.0f/dir.x, 1.0f/dir.y, 1.0f/dir.z};
        float t1=(min.x-origin.x)*inv.x, t2=(max.x-origin.x)*inv.x;
        float t3=(min.y-origin.y)*inv.y, t4=(max.y-origin.y)*inv.y;
        float t5=(min.z-origin.z)*inv.z, t6=(max.z-origin.z)*inv.z;
        float tmin=fmaxf(fmaxf(fminf(t1,t2),fminf(t3,t4)),fminf(t5,t6));
        float tmax=fminf(fminf(fmaxf(t1,t2),fmaxf(t3,t4)),fmaxf(t5,t6));
        return tmax>=0&&tmin<=tmax ? tmin : -1.0f;
    }
};

// ============================================================================
//  Plane
// ============================================================================

struct Plane {
    vec3  normal;
    float d;

    inline Plane() : normal(0,1,0), d(0) {}
    inline Plane(const vec3& n, float d) : normal(n.normalize()), d(d) {}
    inline Plane(const vec3& n, const vec3& p) : normal(n.normalize()), d(-dot(n.normalize(), p)) {}
    inline Plane(const vec3& a, const vec3& b, const vec3& c)
        : Plane(cross(b-a, c-a), a) {}

    inline float distance(const vec3& p) const { return dot(normal, p) + d; }
    inline bool  onPositiveSide(const vec3& p) const { return distance(p) >= 0.0f; }
    inline vec3  project(const vec3& p) const { return p - normal * distance(p); }
};

// ============================================================================
//  Frustum (6 planes)
// ============================================================================

struct Frustum {
    Plane planes[6]; // left, right, bottom, top, near, far

    inline void fromMatrix(const mat4& vp) {
        // Left
        planes[0] = Plane({vp.m[0][3]+vp.m[0][0], vp.m[1][3]+vp.m[1][0], vp.m[2][3]+vp.m[2][0]},
                           vp.m[3][3]+vp.m[3][0]);
        // Right
        planes[1] = Plane({vp.m[0][3]-vp.m[0][0], vp.m[1][3]-vp.m[1][0], vp.m[2][3]-vp.m[2][0]},
                           vp.m[3][3]-vp.m[3][0]);
        // Bottom
        planes[2] = Plane({vp.m[0][3]+vp.m[0][1], vp.m[1][3]+vp.m[1][1], vp.m[2][3]+vp.m[2][1]},
                           vp.m[3][3]+vp.m[3][1]);
        // Top
        planes[3] = Plane({vp.m[0][3]-vp.m[0][1], vp.m[1][3]-vp.m[1][1], vp.m[2][3]-vp.m[2][1]},
                           vp.m[3][3]-vp.m[3][1]);
        // Near
        planes[4] = Plane({vp.m[0][2], vp.m[1][2], vp.m[2][2]}, vp.m[3][2]);
        // Far
        planes[5] = Plane({vp.m[0][3]-vp.m[0][2], vp.m[1][3]-vp.m[1][2], vp.m[2][3]-vp.m[2][2]},
                           vp.m[3][3]-vp.m[3][2]);
    }

    inline bool containsPoint(const vec3& p) const {
        for (int i = 0; i < 6; ++i)
            if (planes[i].distance(p) < 0) return false;
        return true;
    }

    inline bool intersectsAABB(const AABB& b) const {
        for (int i = 0; i < 6; ++i) {
            vec3 pv = {
                planes[i].normal.x > 0 ? b.max.x : b.min.x,
                planes[i].normal.y > 0 ? b.max.y : b.min.y,
                planes[i].normal.z > 0 ? b.max.z : b.min.z
            };
            if (planes[i].distance(pv) < 0) return false;
        }
        return true;
    }
};

// ============================================================================
//  Ray
// ============================================================================

struct Ray {
    vec3 origin, dir;

    inline Ray() : origin(0), dir(0,0,-1) {}
    inline Ray(const vec3& o, const vec3& d) : origin(o), dir(d.normalize()) {}

    inline vec3 at(float t) const { return origin + dir * t; }

    // Ray-sphere intersection (returns t or -1)
    inline float intersectSphere(const vec3& center, float radius) const {
        vec3  oc = origin - center;
        float b  = dot(oc, dir);
        float c  = dot(oc, oc) - radius*radius;
        float disc = b*b - c;
        if (disc < 0) return -1.0f;
        float sq = asm_sqrtf(disc);
        float t  = -b - sq;
        if (t > 0) return t;
        t = -b + sq;
        return t > 0 ? t : -1.0f;
    }

    // Ray-plane intersection
    inline float intersectPlane(const Plane& p) const {
        float denom = dot(p.normal, dir);
        if (abs_f(denom) < EPSILON) return -1.0f;
        return -(dot(p.normal, origin) + p.d) / denom;
    }

    // Ray-triangle intersection (Möller–Trumbore)
    inline float intersectTriangle(const vec3& v0, const vec3& v1, const vec3& v2, vec3* bary = nullptr) const {
        vec3 e1 = v1 - v0, e2 = v2 - v0;
        vec3 h  = cross(dir, e2);
        float a = dot(e1, h);
        if (abs_f(a) < EPSILON) return -1.0f;
        float f = 1.0f / a;
        vec3  s = origin - v0;
        float u = f * dot(s, h);
        if (u < 0 || u > 1) return -1.0f;
        vec3  q = cross(s, e1);
        float v = f * dot(dir, q);
        if (v < 0 || u + v > 1) return -1.0f;
        float t = f * dot(e2, q);
        if (t < EPSILON) return -1.0f;
        if (bary) *bary = {1.0f - u - v, u, v};
        return t;
    }
};

