            static bool str_match(const char* a, const char* b) {
                if (!a || !b) return false;
                while (*a && (*a == *b)) { a++; b++; }
                return *a == *b;
            }

            IDK::Key map_keysym(xkb_keysym_t sym) {
                switch(sym) {
                    case XKB_KEY_a: case XKB_KEY_A: return IDK::Key::A;
                    case XKB_KEY_b: case XKB_KEY_B: return IDK::Key::B;
                    case XKB_KEY_c: case XKB_KEY_C: return IDK::Key::C;
                    case XKB_KEY_d: case XKB_KEY_D: return IDK::Key::D;
                    case XKB_KEY_e: case XKB_KEY_E: return IDK::Key::E;
                    case XKB_KEY_f: case XKB_KEY_F: return IDK::Key::F;
                    case XKB_KEY_g: case XKB_KEY_G: return IDK::Key::G;
                    case XKB_KEY_h: case XKB_KEY_H: return IDK::Key::H;
                    case XKB_KEY_i: case XKB_KEY_I: return IDK::Key::I;
                    case XKB_KEY_j: case XKB_KEY_J: return IDK::Key::J;
                    case XKB_KEY_k: case XKB_KEY_K: return IDK::Key::K;
                    case XKB_KEY_l: case XKB_KEY_L: return IDK::Key::L;
                    case XKB_KEY_m: case XKB_KEY_M: return IDK::Key::M;
                    case XKB_KEY_n: case XKB_KEY_N: return IDK::Key::N;
                    case XKB_KEY_o: case XKB_KEY_O: return IDK::Key::O;
                    case XKB_KEY_p: case XKB_KEY_P: return IDK::Key::P;
                    case XKB_KEY_q: case XKB_KEY_Q: return IDK::Key::Q;
                    case XKB_KEY_r: case XKB_KEY_R: return IDK::Key::R;
                    case XKB_KEY_s: case XKB_KEY_S: return IDK::Key::S;
                    case XKB_KEY_t: case XKB_KEY_T: return IDK::Key::T;
                    case XKB_KEY_u: case XKB_KEY_U: return IDK::Key::U;
                    case XKB_KEY_v: case XKB_KEY_V: return IDK::Key::V;
                    case XKB_KEY_w: case XKB_KEY_W: return IDK::Key::W;
                    case XKB_KEY_x: case XKB_KEY_X: return IDK::Key::X;
                    case XKB_KEY_y: case XKB_KEY_Y: return IDK::Key::Y;
                    case XKB_KEY_z: case XKB_KEY_Z: return IDK::Key::Z;
                    case XKB_KEY_0: return IDK::Key::N0; case XKB_KEY_1: return IDK::Key::N1; case XKB_KEY_2: return IDK::Key::N2; case XKB_KEY_3: return IDK::Key::N3; case XKB_KEY_4: return IDK::Key::N4; case XKB_KEY_5: return IDK::Key::N5; case XKB_KEY_6: return IDK::Key::N6; case XKB_KEY_7: return IDK::Key::N7; case XKB_KEY_8: return IDK::Key::N8; case XKB_KEY_9: return IDK::Key::N9;
                    case XKB_KEY_Escape: return IDK::Key::ESCAPE; case XKB_KEY_space: return IDK::Key::SPACE; case XKB_KEY_Return: return IDK::Key::ENTER; case XKB_KEY_Tab: return IDK::Key::TAB; case XKB_KEY_BackSpace: return IDK::Key::BACKSPACE;
                    case XKB_KEY_Shift_L: return IDK::Key::LEFT_SHIFT; case XKB_KEY_Shift_R: return IDK::Key::RIGHT_SHIFT; case XKB_KEY_Control_L: return IDK::Key::LEFT_CTRL; case XKB_KEY_Control_R: return IDK::Key::RIGHT_CTRL;
                    case XKB_KEY_exclam: return IDK::Key::EXCLAMATION; case XKB_KEY_at: return IDK::Key::AT; case XKB_KEY_numbersign: return IDK::Key::HASH; case XKB_KEY_dollar: return IDK::Key::DOLLAR; case XKB_KEY_percent: return IDK::Key::PERCENT; case XKB_KEY_asciicircum: return IDK::Key::CARET; case XKB_KEY_ampersand: return IDK::Key::AMPERSAND; case XKB_KEY_asterisk: return IDK::Key::ASTERISK;
                    case XKB_KEY_parenleft: return IDK::Key::PAREN_LEFT; case XKB_KEY_parenright: return IDK::Key::PAREN_RIGHT; case XKB_KEY_minus: return IDK::Key::MINUS; case XKB_KEY_equal: return IDK::Key::EQUAL; case XKB_KEY_plus: return IDK::Key::PLUS; case XKB_KEY_underscore: return IDK::Key::UNDERSCORE;
                    default: return IDK::Key::UNKNOWN;
                }
            }

            static void kb_keymap(void* d, wl_keyboard* k, uint32_t f, int32_t fd, uint32_t s) {
                wWindow_s* self = static_cast<wWindow_s*>(d); (void)k; (void)f;
                char* m = (char*)mmap(NULL, s, PROT_READ, MAP_SHARED, fd, 0);
                if (m != MAP_FAILED) {
                    if (self->m_xkb_map) xkb_keymap_unref(self->m_xkb_map);
                    self->m_xkb_map = xkb_keymap_new_from_string(self->m_xkb_ctx, m, XKB_KEYMAP_FORMAT_TEXT_V1, XKB_KEYMAP_COMPILE_NO_FLAGS);
                    munmap(m, s);
                    if (self->m_xkb_state) xkb_state_unref(self->m_xkb_state);
                    self->m_xkb_state = xkb_state_new(self->m_xkb_map);
                }
                asm_close(fd);
            }

            static void kb_key(void* d, wl_keyboard* k, uint32_t s, uint32_t t, uint32_t key, uint32_t state) {
                wWindow_s* self = static_cast<wWindow_s*>(d); (void)k; (void)s; (void)t;
                if (!self->m_xkb_state) return;
                xkb_keysym_t sym = xkb_state_key_get_one_sym(self->m_xkb_state, key + 8);
                IDK::Key IDK_key = self->map_keysym(sym);
                if (IDK_key != IDK::Key::UNKNOWN) {
                    if (state == WL_KEYBOARD_KEY_STATE_PRESSED) {
                        if (self->m_keys[(int)IDK_key] == IDK::InputState::IDLE || self->m_keys[(int)IDK_key] == IDK::InputState::RELEASED)
                            self->m_keys[(int)IDK_key] = IDK::InputState::PRESSED;
                    } else self->m_keys[(int)IDK_key] = IDK::InputState::RELEASED;
                }
                if (sym == XKB_KEY_Escape && state == WL_KEYBOARD_KEY_STATE_PRESSED) self->m_running = false;
            }

            static void ptr_enter(void* d, wl_pointer* p, uint32_t s, wl_surface* sf, wl_fixed_t sx, wl_fixed_t sy) {
                wWindow_s* self = (wWindow_s*)d; (void)p; (void)s; (void)sf;
                self->m_mouse_x = wl_fixed_to_double(sx); self->m_mouse_y = wl_fixed_to_double(sy);
            }
            static void ptr_motion(void* d, wl_pointer* p, uint32_t t, wl_fixed_t sx, wl_fixed_t sy) {
                wWindow_s* self = (wWindow_s*)d; (void)p; (void)t;
                self->m_mouse_x = wl_fixed_to_double(sx); self->m_mouse_y = wl_fixed_to_double(sy);
            }
            static void ptr_button(void* d, wl_pointer* p, uint32_t s, uint32_t t, uint32_t b, uint32_t st) {
                wWindow_s* self = (wWindow_s*)d; (void)p; (void)s; (void)t;
                IDK::MouseButton mb = IDK::MouseButton::COUNT;
                if (b == 0x110) mb = IDK::MouseButton::LEFT;
                else if (b == 0x111) mb = IDK::MouseButton::RIGHT;
                else if (b == 0x112) mb = IDK::MouseButton::MIDDLE;
                if (mb != IDK::MouseButton::COUNT) {
                    if (st == WL_POINTER_BUTTON_STATE_PRESSED) self->m_mouse_btns[(int)mb] = IDK::InputState::PRESSED;
                    else self->m_mouse_btns[(int)mb] = IDK::InputState::RELEASED;
                }
            }

            static int create_shm_file(int size) {
                int fd = memfd_create("w-shm", MFD_CLOEXEC);
                if (fd < 0) {
                    fd = -1;
                    const char* tmp = ctCX_GetEnv("XDG_RUNTIME_DIR");
                    if (!tmp) tmp = "/tmp";
                    // Build path with aString, then hand writable buffer to mkostemp
                    rstd::aString path(tmp);
                    path += "/w-shm-XXXXXX";
                    fd = mkostemp(path.writable(), O_CLOEXEC);
                    if (fd >= 0) asm_unlink(path.c_str());
                }
                if (fd >= 0) asm_ftruncate(fd, size);
                return fd;
            }

            inline void recreate_shm_buffer() {
                if (m_dummy_buffer) { wl_buffer_destroy(m_dummy_buffer); m_dummy_buffer = nullptr; }
                if (m_shm_pool) { wl_shm_pool_destroy(m_shm_pool); m_shm_pool = nullptr; }
                if (m_shm_data) { munmap(m_shm_data, m_shm_size); m_shm_data = nullptr; }
                if (m_shm_fd >= 0) { asm_close(m_shm_fd); m_shm_fd = -1; }

                int stride = m_width * 4;
                m_shm_size = stride * m_height;
                if (m_shm_size <= 0) return;

                m_shm_fd = create_shm_file(m_shm_size);
                if (m_shm_fd < 0) { log_err("SHM file creation failed"); return; }

                m_shm_data = mmap(NULL, m_shm_size, PROT_READ | PROT_WRITE, MAP_SHARED, m_shm_fd, 0);
                if (m_shm_data == MAP_FAILED) { m_shm_data = nullptr; log_err("SHM mmap failed"); asm_close(m_shm_fd); m_shm_fd = -1; return; }

                m_shm_pool = wl_shm_create_pool(m_shm, m_shm_fd, m_shm_size);
                m_dummy_buffer = wl_shm_pool_create_buffer(m_shm_pool, 0, m_width, m_height, stride, WL_SHM_FORMAT_ARGB8888);

                uint32_t* pixels = (uint32_t*)m_shm_data;
                for (int i = 0; i < m_width * m_height; i++) pixels[i] = 0xFF5599DD; // default blue
            }

            inline void fill_dark() {
                if (!m_shm_data) return;
                uint32_t* pixels = (uint32_t*)m_shm_data;
                for (int i = 0; i < m_width * m_height; i++) pixels[i] = 0xFF5599DD; // default blue
            }

            static void xdg_wm_base_ping(void* d, struct xdg_wm_base* wm, uint32_t s) { xdg_wm_base_pong(wm, s); (void)d; }
            static void xdg_surface_configure(void* d, struct xdg_surface* sf, uint32_t sr) {
                wWindow_s* self = (wWindow_s*)d;
                xdg_surface_ack_configure(sf, sr);
                self->m_configured = true;
            }
            static void xdg_toplevel_configure(void* d, struct xdg_toplevel* tl, int32_t w, int32_t h, struct wl_array* st) {
                wWindow_s* self = (wWindow_s*)d; (void)tl; (void)st;
                if (w > 0 && h > 0 && (self->m_width != w || self->m_height != h)) {
                    self->m_width = w; self->m_height = h; self->m_pending_resize = true;
                }
            }

            inline void setup_frame_callback() {
                if (m_frame_cb) { wl_callback_destroy(m_frame_cb); m_frame_cb = nullptr; }
                static const wl_callback_listener l = { .done = [](void* d, wl_callback* cb, uint32_t time) {
                    wWindow_s* s = (wWindow_s*)d; (void)time;
                    wl_callback_destroy(cb); s->m_frame_cb = nullptr;
                    if (s->m_pending_resize) { s->m_pending_resize = false; s->recreate_shm_buffer(); }
                    if (s->m_dummy_buffer) {
                        wl_surface_attach(s->m_surface, s->m_dummy_buffer, 0, 0);
                        wl_surface_damage_buffer(s->m_surface, 0, 0, s->m_width, s->m_height);
                    }
                    wl_surface_commit(s->m_surface);
                    s->setup_frame_callback();
                }};
                m_frame_cb = wl_surface_frame(m_surface);
                wl_callback_add_listener(m_frame_cb, &l, this);
            }

            static void seat_handle_caps(void* d, wl_seat* st, uint32_t caps) {
                wWindow_s* self = (wWindow_s*)d;
                if ((caps & WL_SEAT_CAPABILITY_KEYBOARD) && !self->m_keyboard) {
                    self->m_keyboard = wl_seat_get_keyboard(st);
                    static const wl_keyboard_listener l = { .keymap = kb_keymap, .enter = [](void* d, wl_keyboard* k, uint32_t s, wl_surface* sf, wl_array* ks){((wWindow_s*)d)->m_focused = true; (void)k;(void)s;(void)sf;(void)ks;}, .leave = [](void* d, wl_keyboard* k, uint32_t s, wl_surface* sf){((wWindow_s*)d)->m_focused = false; (void)k;(void)s;(void)sf;}, .key = kb_key, .modifiers = [](void* d, wl_keyboard* k, uint32_t s, uint32_t m, uint32_t l, uint32_t g, uint32_t v){ if(((wWindow_s*)d)->m_xkb_state) xkb_state_update_mask(((wWindow_s*)d)->m_xkb_state, m, l, g, 0, 0, v); (void)k;(void)s; }, .repeat_info = [](void* d, wl_keyboard* k, int32_t r, int32_t dl){(void)d;(void)k;(void)r;(void)dl;} };
                    wl_keyboard_add_listener(self->m_keyboard, &l, self);
                }
                if ((caps & WL_SEAT_CAPABILITY_POINTER) && !self->m_pointer) {
                    self->m_pointer = wl_seat_get_pointer(st);
                    static wl_pointer_listener l{};
                    l.enter = ptr_enter;
                    l.leave = [](void* d, wl_pointer* p, uint32_t s, wl_surface* sf){(void)d;(void)p;(void)s;(void)sf;};
                    l.motion = ptr_motion;
                    l.button = ptr_button;
                    l.axis = [](void* d, wl_pointer* p, uint32_t t, uint32_t a, wl_fixed_t v){(void)d;(void)p;(void)t;(void)a;(void)v;};
                    wl_pointer_add_listener(self->m_pointer, &l, self);
                }
            }

            static void reg_global(void* d, wl_registry* r, uint32_t id, const char* i, uint32_t v) {
                wWindow_s* self = (wWindow_s*)d; (void)v;
                if (str_match(i, "wl_compositor")) self->m_compositor = (wl_compositor*)wl_registry_bind(r, id, &wl_compositor_interface, 4);
                else if (str_match(i, "xdg_wm_base")) { self->m_xdg_wm_base = (xdg_wm_base*)wl_registry_bind(r, id, &xdg_wm_base_interface, 1); static const xdg_wm_base_listener l = { .ping = xdg_wm_base_ping }; xdg_wm_base_add_listener(self->m_xdg_wm_base, &l, self); }
                else if (str_match(i, "wl_seat")) { self->m_seat = (wl_seat*)wl_registry_bind(r, id, &wl_seat_interface, 1); static const wl_seat_listener l = { .capabilities = seat_handle_caps, .name = [](void* d, wl_seat* s, const char* n){(void)d;(void)s;(void)n;} }; wl_seat_add_listener(self->m_seat, &l, self); }
                else if (str_match(i, "wl_output") && !self->m_output) self->m_output = (wl_output*)wl_registry_bind(r, id, &wl_output_interface, 1);
                else if (str_match(i, "wl_shm")) self->m_shm = (wl_shm*)wl_registry_bind(r, id, &wl_shm_interface, 1);
            }

        public:
            inline wWindow_s(int width = 800, int height = 600) 
                : m_display(nullptr), m_registry(nullptr), m_compositor(nullptr), m_surface(nullptr), m_xdg_wm_base(nullptr), m_xdg_surface(nullptr), m_xdg_toplevel(nullptr), m_seat(nullptr), m_keyboard(nullptr), m_pointer(nullptr), m_output(nullptr), m_shm(nullptr),
                  m_dummy_buffer(nullptr), m_frame_cb(nullptr), m_shm_data(nullptr), m_shm_size(0), m_shm_fd(-1), m_shm_pool(nullptr), m_pending_resize(false),
                  m_width(width), m_height(height), m_vsync(1), m_running(true), m_configured(false), m_fullscreen(false), m_focused(false), m_mouse_x(0), m_mouse_y(0) {
                for(int i = 0; i < (int)IDK::Key::COUNT; i++) m_keys[i] = IDK::InputState::IDLE;
                for(int i = 0; i < (int)IDK::MouseButton::COUNT; i++) m_mouse_btns[i] = IDK::InputState::IDLE;
                m_xkb_ctx = xkb_context_new(XKB_CONTEXT_NO_FLAGS); m_xkb_map = nullptr; m_xkb_state = nullptr;
            }

            inline void fullscreen(bool e = true) {
                m_fullscreen = e;
                if (m_xdg_toplevel) {
                    if (e) xdg_toplevel_set_fullscreen(m_xdg_toplevel, m_output);
                    else xdg_toplevel_unset_fullscreen(m_xdg_toplevel);
                    wl_surface_commit(m_surface);
                    wl_display_roundtrip(m_display);
                }
            }
            inline void vsync(int n) { m_vsync = n; }
            inline bool WindowFocusState() const { return m_focused; }
            inline void setWindowSize(int w, int h) { m_width = w; m_height = h; }
            inline void addWindowSize(int dw, int dh) { m_width += dw; m_height += dh; }
            inline void setWindowPosition(int x, int y) { (void)x; (void)y; }

            inline IDK::InputState getKeyState(IDK::Key k) const { return m_keys[(int)k]; }
            inline IDK::InputState getMouseState(IDK::MouseButton b) const { return m_mouse_btns[(int)b]; }
            inline void getMousePosition(double& x, double& y) const { x = m_mouse_x; y = m_mouse_y; }
            inline void getFramebufferMousePosition(double& x, double& y) const { x = m_mouse_x; y = m_mouse_y; }

            inline void init() {
                log_info("Initializing Wayland window...");
                m_display = wl_display_connect(nullptr);
                if (!m_display) { log_err("Connection failed!"); return; }
                m_registry = wl_display_get_registry(m_display);
                static const wl_registry_listener rl = { .global = reg_global, .global_remove = [](void* d, wl_registry* r, uint32_t id){(void)d;(void)r;(void)id;} };
                wl_registry_add_listener(m_registry, &rl, this);
                wl_display_roundtrip(m_display); wl_display_roundtrip(m_display);
                if (!m_compositor || !m_xdg_wm_base || !m_shm) { log_err("Missing required globals!"); return; }
                m_surface = wl_compositor_create_surface(m_compositor);
                static wl_surface_listener surf_l{};
                surf_l.enter = [](void* d, wl_surface* s, wl_output* o) { ((wWindow_s*)d)->m_output = o; (void)s; };
                surf_l.leave = [](void* d, wl_surface* s, wl_output* o) { if (((wWindow_s*)d)->m_output == o) ((wWindow_s*)d)->m_output = nullptr; (void)s; (void)o; };
                wl_surface_add_listener(m_surface, &surf_l, this);
                m_xdg_surface = xdg_wm_base_get_xdg_surface(m_xdg_wm_base, m_surface);
                static const struct xdg_surface_listener sl = { .configure = xdg_surface_configure };
                xdg_surface_add_listener(m_xdg_surface, &sl, this);
                m_xdg_toplevel = xdg_surface_get_toplevel(m_xdg_surface);
                static const struct xdg_toplevel_listener tl = { .configure = xdg_toplevel_configure, .close = [](void* d, xdg_toplevel* t){((wWindow_s*)d)->m_running = false; (void)t;}, .configure_bounds = [](void* d, xdg_toplevel* t, int32_t w, int32_t h){(void)d;(void)t;(void)w;(void)h;}, .wm_capabilities = [](void* d, xdg_toplevel* t, wl_array* c){(void)d;(void)t;(void)c;} };
                xdg_toplevel_add_listener(m_xdg_toplevel, &tl, this);
                xdg_toplevel_set_title(m_xdg_toplevel, "HellaAssVulkanProject");
                xdg_toplevel_set_app_id(m_xdg_toplevel, "HellaAssVulkanProject");
                if (m_fullscreen) xdg_toplevel_set_fullscreen(m_xdg_toplevel, m_output);
                wl_surface_commit(m_surface);
                while (!m_configured && wl_display_dispatch(m_display) != -1);
                recreate_shm_buffer();
                wl_surface_attach(m_surface, m_dummy_buffer, 0, 0);
                wl_surface_damage_buffer(m_surface, 0, 0, m_width, m_height);
                wl_surface_commit(m_surface);
                setup_frame_callback();
                log_info("Window ready.");
            }

            inline void updateInputStates() {
                for(int i = 0; i < (int)IDK::Key::COUNT; i++) {
                    if (m_keys[i] == IDK::InputState::PRESSED) m_keys[i] = IDK::InputState::HELD;
                    else if (m_keys[i] == IDK::InputState::RELEASED) m_keys[i] = IDK::InputState::IDLE;
                }
                for(int i = 0; i < (int)IDK::MouseButton::COUNT; i++) {
                    if (m_mouse_btns[i] == IDK::InputState::PRESSED) m_mouse_btns[i] = IDK::InputState::HELD;
                    else if (m_mouse_btns[i] == IDK::InputState::RELEASED) m_mouse_btns[i] = IDK::InputState::IDLE;
                }
            }

            inline void run() {
                if (!m_running) return;
                wl_display_flush(m_display);
                while (wl_display_prepare_read(m_display) != 0) {
                    if (wl_display_dispatch_pending(m_display) == -1) { m_running = false; return; }
                }
                struct pollfd pfd = { wl_display_get_fd(m_display), POLLIN, 0 };
                if (poll(&pfd, 1, 0) > 0) {
                    wl_display_read_events(m_display);
                    if (wl_display_dispatch_pending(m_display) == -1) m_running = false;
                } else {
                    wl_display_cancel_read(m_display);
                }
            }

            inline VkSurfaceKHR createVulkanSurface(VkInstance instance) {
                if (!m_display || !m_surface) return VK_NULL_HANDLE;
                VkWaylandSurfaceCreateInfoKHR ci = {};
                ci.sType = VK_STRUCTURE_TYPE_WAYLAND_SURFACE_CREATE_INFO_KHR;
                ci.display = m_display;
                ci.surface = m_surface;
                VkSurfaceKHR vkSurface; if (vkCreateWaylandSurfaceKHR(instance, &ci, nullptr, &vkSurface) != VK_SUCCESS) return VK_NULL_HANDLE;
                return vkSurface;
            }

            inline void cleanup() {
                if (m_frame_cb) { wl_callback_destroy(m_frame_cb); m_frame_cb = nullptr; }
                if (m_dummy_buffer) { wl_buffer_destroy(m_dummy_buffer); m_dummy_buffer = nullptr; }
                if (m_shm_pool) { wl_shm_pool_destroy(m_shm_pool); m_shm_pool = nullptr; }
                if (m_shm_data) { munmap(m_shm_data, m_shm_size); m_shm_data = nullptr; }
                if (m_shm_fd >= 0) { asm_close(m_shm_fd); m_shm_fd = -1; }
                if (m_shm) { wl_shm_destroy(m_shm); m_shm = nullptr; }
                if (m_pointer) wl_pointer_destroy(m_pointer);
                if (m_keyboard) wl_keyboard_destroy(m_keyboard);
                if (m_seat) wl_seat_destroy(m_seat);
                if (m_output) wl_output_destroy(m_output);
                if (m_xdg_toplevel) xdg_toplevel_destroy(m_xdg_toplevel);
                if (m_xdg_surface) xdg_surface_destroy(m_xdg_surface);
                if (m_xdg_wm_base) xdg_wm_base_destroy(m_xdg_wm_base);
                if (m_surface) wl_surface_destroy(m_surface);
                if (m_compositor) wl_compositor_destroy(m_compositor);
                if (m_registry) wl_registry_destroy(m_registry);
                if (m_xkb_state) xkb_state_unref(m_xkb_state);
                if (m_xkb_map) xkb_keymap_unref(m_xkb_map);
                if (m_xkb_ctx) xkb_context_unref(m_xkb_ctx);
                if (m_display) wl_display_disconnect(m_display);
                log_info("Cleanup complete.");
            }

            inline int get_width() const { return m_width; }
            inline int get_height() const { return m_height; }
            inline wl_display* getDisplay() { return m_display; }
            inline bool isRunning() const { return m_running; }
    };
