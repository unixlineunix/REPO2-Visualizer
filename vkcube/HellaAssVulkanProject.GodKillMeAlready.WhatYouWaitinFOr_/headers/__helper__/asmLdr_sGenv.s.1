namespace rstd {

    // ... (Keep your current Ostream, cout, cerr, endl, and flush completely intact here)

    // 2. Add the dynamic lookup handler method right under your stream variables
    inline rstd::aString getenv(const char* var_name) {
        if (!var_name) return rstd::aString();
        
        const char* value_ptr = ctCX_GetEnv(var_name);
        if (value_ptr) {
            return rstd::aString(value_ptr); // Direct constructor assignment loads and copies text automatically
        }
        return rstd::aString(); // Return completely empty blank object if lookup falls flat
    }
}

