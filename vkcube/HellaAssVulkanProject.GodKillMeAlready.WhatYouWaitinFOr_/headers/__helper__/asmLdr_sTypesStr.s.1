#pragma once
#ifndef RSTD_ASTRING_HPP
#define RSTD_ASTRING_HPP

// size_t_raw defined below, no cstddef needed

typedef unsigned long long size_t_raw;

// write replaced by asm_rawPrintStr

extern "C" {
    void _ZdaPv(void* ptr);

    void ctCX_Append(void* struct_ptr, const char* text);
    void ctCX_DynCstInt(void* struct_ptr, long long number);
    void ctCX_Free(void* struct_ptr);

    const char* ctCX_GetCStr(const void* struct_ptr);
    char*       ctCX_GetWritable(void* struct_ptr);
    void        ctCX_RecalcLen(void* struct_ptr);

    void asm_rawPrintStr(int fd, const char* text);
    void asm_rawPrintDynStr(int fd, const void* struct_ptr);
    void asm_rawPrintInt(int fd, long long number);
}

namespace rstd {

class aString {
private:

    struct alignas(8) DynStrgLayout {
        char* baseBuffer = nullptr;
        size_t_raw currentLength = 0;
        size_t_raw maxCapacity = 0;
    } instance;

public:

    // -------------------------
    // Constructors
    // -------------------------
    inline aString() = default;

    inline aString(const char* text) {
        if (text) {
            ctCX_Append(&instance, text);
        }
    }

    inline aString(long long number) {
        ctCX_DynCstInt(&instance, number);
    }

    inline aString(const aString& other) {
        const char* src = other.c_str();
        if (src) {
            ctCX_Append(&instance, src);
        }
    }

    inline aString(aString&& other) noexcept {
        instance = other.instance;
        other.instance.baseBuffer = nullptr;
        other.instance.currentLength = 0;
        other.instance.maxCapacity = 0;
    }

    inline aString& operator=(const aString& other) {
        if (this != &other) {
            ctCX_Free(&instance);
            const char* src = other.c_str();
            if (src) {
                ctCX_Append(&instance, src);
            }
        }
        return *this;
    }

    inline aString& operator=(aString&& other) noexcept {
        if (this != &other) {
            ctCX_Free(&instance);
            instance = other.instance;
            other.instance.baseBuffer = nullptr;
            other.instance.currentLength = 0;
            other.instance.maxCapacity = 0;
        }
        return *this;
    }

    inline ~aString() {
        ctCX_Free(&instance);
    }

    // -------------------------
    // Append API
    // -------------------------
    inline aString& append(const char* text) {
        if (text) {
            ctCX_Append(&instance, text);
        }
        return *this;
    }

    inline aString& appendInt(long long number) {
        ctCX_DynCstInt(&instance, number);
        return *this;
    }

    // -------------------------
    // Raw access
    // -------------------------
    inline const char* c_str() const {
        return ctCX_GetCStr(&instance);
    }

    // Returns writable char* for APIs like mkostemp that modify the buffer in-place.
    // Call recalc_len() after the external call to resync the length field.
    inline char* writable() {
        return ctCX_GetWritable(&instance);
    }

    // Resyncs the length after external in-place modification of the buffer.
    inline void recalc_len() {
        ctCX_RecalcLen(&instance);
    }

    inline const void* get_struct_ptr() const {
        return &instance;
    }

    inline size_t_raw length() const {
        return instance.currentLength;
    }

    // -------------------------
    // Output
    // -------------------------
    inline void display() const {
        if (instance.baseBuffer && instance.currentLength > 0) {
            asm_rawPrintStr(1, instance.baseBuffer);
        }
    }

    // -------------------------
    // Operators
    // -------------------------
    inline aString& operator+=(const aString& other) {
        const char* raw = other.c_str();
        if (raw) {
            ctCX_Append(&instance, raw);
        }
        return *this;
    }

    inline aString& operator+=(const char* text) {
        if (text) {
            ctCX_Append(&instance, text);
        }
        return *this;
    }

    inline aString operator+(const aString& other) const {
        aString result(c_str());
        result += other;
        return result;
    }

    inline aString operator+(const char* text) const {
        aString result(c_str());
        result += text;
        return result;
    }
};

} // namespace rstd

#endif