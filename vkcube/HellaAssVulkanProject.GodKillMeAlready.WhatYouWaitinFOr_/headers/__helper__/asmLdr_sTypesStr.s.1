///////// //////// /  / ////// / // /             // NGL: basically 64 bits
///////// //////// /  / ////// / // /             struct alignas(8) DynStrgLayout {
///////// //////// /  / ////// / // /                 char*          baseBuffer    = nullptr; // [Offset: 0]  :- Base memory buffer address pointer (char*)
///////// //////// /  / ////// / // /                 size_t_raw     currentLength = 0;       // [Offset: 8]  :- Current tracking length of text characters
///////// //////// /  / ////// / // /                 size_t_raw     maxCapacity   = 0;       // [Offset: 16] :- Max capacity threshold limit allocation
///////// //////// /  / ////// / // /             } instance;
