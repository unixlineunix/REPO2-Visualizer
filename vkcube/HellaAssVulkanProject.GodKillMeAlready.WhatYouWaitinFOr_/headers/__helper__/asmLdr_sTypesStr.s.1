///////// //////// /  / ////// / // /                 if (instance.baseBuffer && instance.currentLength > 0) {
///////// //////// /  / ////// / // /                     write(1, instance.baseBuffer, instance.currentLength);
///////// //////// /  / ////// / // /                     write(1, "\n", 1);
///////// //////// /  / ////// / // /                 }
///////// //////// /  / ////// / // /             }
///////// //////// /  / ////// / // / 
///////// //////// /  / ////// / // /             // ─── OVERLOADED MATH OPERATORS ───
///////// //////// /  / ////// / // /             inline aString& operator+=(const aString& other) {
///////// //////// /  / ////// / // /                 const char* raw_text = ctCX_GetCStr(const_cast<void*>(other.get_struct_ptr()));
///////// //////// /  / ////// / // /                 if (raw_text) {
