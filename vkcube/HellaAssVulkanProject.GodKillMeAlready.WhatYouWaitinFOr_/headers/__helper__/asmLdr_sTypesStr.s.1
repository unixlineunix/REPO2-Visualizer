///////// //////// /  / ////// / // /                 ctCX_Append(&instance, text);
///////// //////// /  / ////// / // /                 return *this;
///////// //////// /  / ////// / // /             }
///////// //////// /  / ////// / // / 
///////// //////// /  / ////// / // /             inline aString& appendInt(long long number) {
///////// //////// /  / ////// / // /                 ctCX_DynCstInt(&instance, number);
///////// //////// /  / ////// / // /                 return *this;
///////// //////// /  / ////// / // /             }
///////// //////// /  / ////// / // / 
///////// //////// /  / ////// / // /             // ─── `.c_str()` METHOD ───
///////// //////// /  / ////// / // /             inline const char* c_str() {
///////// //////// /  / ////// / // /                 return ctCX_GetCStr(&instance);
///////// //////// /  / ////// / // /             }
///////// //////// /  / ////// / // / 
///////// //////// /  / ////// / // /             inline const void* get_struct_ptr() const { return &instance; }
///////// //////// /  / ////// / // /     
///////// //////// /  / ////// / // /             inline size_t_raw length() const {
///////// //////// /  / ////// / // /                 return instance.currentLength;
///////// //////// /  / ////// / // /             }
