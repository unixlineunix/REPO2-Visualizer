///////// //////// /  / ////// / // /             inline aString(const char* text) {
///////// //////// /  / ////// / // /                 instance.baseBuffer    = nullptr;
///////// //////// /  / ////// / // /                 instance.currentLength = 0;
///////// //////// /  / ////// / // /                 instance.maxCapacity   = 0;
///////// //////// /  / ////// / // /                 if (text) {
///////// //////// /  / ////// / // /                     ctCX_Append(&instance, text);
///////// //////// /  / ////// / // /                 }
///////// //////// /  / ////// / // /             }
///////// //////// /  / ////// / // / 
///////// //////// /  / ////// / // /             // ─── DIRECT INT ASSIGNMENT CONSTRUCTOR (Casting) ───
///////// //////// /  / ////// / // /             // This allows: aString str = 42; or to_aString handler bindings
///////// //////// /  / ////// / // /             inline aString(long long number) {
///////// //////// /  / ////// / // /                 instance.baseBuffer    = nullptr;
///////// //////// /  / ////// / // /                 instance.currentLength = 0;
///////// //////// /  / ////// / // /                 instance.maxCapacity   = 0;
///////// //////// /  / ////// / // /                 
///////// //////// /  / ////// / // /                 // Routes directly into your zero-call stack allocation assembly loop
///////// //////// /  / ////// / // /                 ctCX_DynCstInt(&instance, number);
///////// //////// /  / ////// / // /             }
///////// //////// /  / ////// / // / 
///////// //////// /  / ////// / // /             inline ~aString() { ctCX_Free(&instance); }
///////// //////// /  / ////// / // / 
