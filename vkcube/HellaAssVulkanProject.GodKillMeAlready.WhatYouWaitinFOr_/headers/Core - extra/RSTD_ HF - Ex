        // ─── HIGH-PERFORMANCE EXCEPTION BASE INTERFACE ───
        // Replaces standard std::exception with a zero-overhead object layer
        class exception {
        public:
            inline exception() {}
            inline virtual ~exception() {}
    
            // Virtual contract requiring derived types to return a null-terminated pointer.
            // Mimics std::exception::what() flawlessly.
            virtual const char* what() const noexcept = 0;
        };
    
        // ─── CONCRETE VULKAN RUNTIME EXCEPTION ENGINE ───
        class runtime_error : public exception {
        private:
            rstd::aString message_buffer; // Dynamic memory canvas tracking the exact crash details
    
        public:
            // Constructor converts custom string payloads into locked heap buffers
            inline runtime_error(const char* message) : message_buffer(message) {}
            inline runtime_error(const rstd::aString& message) : message_buffer(message) {}
    
            // Overrides contract to hand back raw memory address pointer locations to your logger
            inline const char* what() const noexcept override {
                // Reaches directly into Offset 0 of your assembly structural data block
                return const_cast<rstd::aString&>(message_buffer).c_str();
            }
