    class Ostream;
    
    // CORRECT SYSTEM ALIAS: Explicitly targets a const Ostream reference stream loop.
    // This fully synchronizes the streaming pipeline left-to-right to clear all Code 312 errors.
    using Manipulator = const Ostream& (*)(const Ostream&);

    class Ostream {
        private:
            int fd; // 1 = STDOUT, 2 = STDERR

        public:
            inline constexpr Ostream(int file_descriptor) : fd(file_descriptor) {}

            // Added 'const' to method signatures to resolve the IntelliSense mismatch
            inline const Ostream& operator<<(const char* text) const {
                asm_rawPrintStr(fd, text);
                return *this;
            }

            inline const Ostream& operator<<(const aString& str) const {
                asm_rawPrintDynStr(fd, str.get_struct_ptr());
                return *this;
            }

            inline const Ostream& operator<<(long long number) const {
                asm_rawPrintInt(fd, number);
                return *this;
            }

            // CORRECT FIXED: Passes the const reference directly into the using alias function pointer
            inline const Ostream& operator<<(Manipulator m) const {
                return m(*this);
            }

            inline int get_fd() const { return fd; }
        };

        // Fixed: Use standard 'inline const' declarations instead of 'constexpr' 
        // to maintain constant globally accessible references without parsing violations
        inline const Ostream cout(1);
        inline const Ostream cerr(2);
        
        // CORRECT FIXED: Synchronized parameter signatures to perfectly bind with the using alias
        inline const Ostream& endl(const Ostream& os) {
            asm_rawPrintStr(os.get_fd(), "\n");
            return os;
        }

        // CORRECT FIXED: Synchronized parameter signatures to perfectly bind with the using alias
        inline const Ostream& flush(const Ostream& os) {
            return os;
        }

