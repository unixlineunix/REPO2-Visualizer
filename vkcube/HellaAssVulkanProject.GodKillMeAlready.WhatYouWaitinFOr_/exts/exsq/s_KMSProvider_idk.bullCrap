#pragma once

#if !defined(___BASIC_WINDOW__PROVIDER__KMS__)
#define ___BASIC_WINDOW__PROVIDER__KMS__

// KMS/DRM direct display provider — runs with no compositor, straight from TTY
// Same public interface as wWindow_s so you can swap between them

#include <xf86drm.h>
#include <xf86drmMode.h>
#include <gbm.h>
#include <vulkan/vulkan.h>
#include <vulkan/vulkan_wayland.h>  // not used here but keep parity with the other provider

#include <fcntl.h>
#include <unistd.h>
#include <poll.h>
#include <sys/mman.h>
#include <sys/ioctl.h>
#include <linux/input.h>
#include <linux/kd.h>
#include <linux/vt.h>
#include <termios.h>
#include <dirent.h>
#include <xkbcommon/xkbcommon.h>

#include "../Core - extra/RSTD_ HF - Ex"
#include "../Utility/reAnsi"
#include "idk_InputDefs.++"

namespace tui = rstd::ansi::CnsChr;

class kWindow_s {
    private:
        // --- DRM ---
        int              m_drm_fd        = -1;
        drmModeRes*      m_drm_res       = nullptr;
        drmModeConnector* m_connector    = nullptr;
        drmModeEncoder*  m_encoder       = nullptr;
        drmModeCrtc*     m_saved_crtc    = nullptr;
        uint32_t         m_crtc_id       = 0;
        drmModeModeInfo  m_mode          = {};

        // --- GBM ---
        gbm_device*      m_gbm_dev       = nullptr;
        gbm_surface*     m_gbm_surface   = nullptr;

        // --- Dumb buffer (for immediate display) ---
        uint32_t         m_dumb_handle   = 0;
        uint32_t         m_dumb_fb       = 0;
        void*            m_dumb_map      = nullptr;
        uint32_t         m_dumb_size     = 0;

        // --- Input (evdev) ---
        static constexpr int MAX_EVDEV = 8;
        int              m_evdev_fds[MAX_EVDEV];
        int              m_evdev_count   = 0;

        // --- TTY state ---
        int              m_tty_fd        = -1;
        struct termios   m_orig_termios  = {};
        int              m_orig_kb_mode  = 0;

        // --- XKB ---
        struct xkb_context* m_xkb_ctx   = nullptr;
        struct xkb_keymap*  m_xkb_map   = nullptr;
        struct xkb_state*   m_xkb_state = nullptr;

        // --- State ---
        int  m_width    = 0;
        int  m_height   = 0;
        bool m_running  = true;
        bool m_focused  = true;

        idk::InputState m_keys[(int)idk::Key::COUNT];
        idk::InputState m_mouse_btns[(int)idk::MouseButton::COUNT];
        double m_mouse_x = 0, m_mouse_y = 0;

        static void log_info(const char* msg) {
            rstd::cout << tui::COLOR::FGCOLORn(39) << tui::STYLE::BOLD << "[KMS::] "
                       << tui::RESET << tui::COLOR::WHITE << tui::STYLE::BOLD << msg
                       << tui::RESET << rstd::endl;
        }

        static void log_err(const char* msg) {
            rstd::cerr << tui::COLOR::RED << tui::STYLE::BOLD << "[KMS::] "
                       << tui::RESET << tui::COLOR::LIGHTBLUE << tui::UL::WIGGLEUNDERLINE << msg
                       << tui::RESET << rstd::endl;
        }

        // --- Find best mode (largest area, prefer native) ---
        drmModeModeInfo* pick_mode(drmModeConnector* c) {
            drmModeModeInfo* best = nullptr;
            for (int i = 0; i < c->count_modes; ++i) {
                if (c->modes[i].type & DRM_MODE_TYPE_PREFERRED)
                    return &c->modes[i];
                if (!best || (c->modes[i].hdisplay * c->modes[i].vdisplay >
                              best->hdisplay * best->vdisplay))
                    best = &c->modes[i];
            }
            return best;
        }

        // --- Open the DRM device ---
        bool open_drm() {
            // Try card1 first (your system), fall back to card0
            const char* cards[] = { "/dev/dri/card1", "/dev/dri/card0", nullptr };
            for (int i = 0; cards[i]; ++i) {
                m_drm_fd = open(cards[i], O_RDWR | O_CLOEXEC);
                if (m_drm_fd < 0) continue;
                m_drm_res = drmModeGetResources(m_drm_fd);
                if (m_drm_res) {
                    rstd::aString msg("Opened DRM device: ");
                    msg += cards[i];
                    log_info(msg.c_str());
                    return true;
                }
                close(m_drm_fd);
                m_drm_fd = -1;
            }
            log_err("No usable DRM device found");
            return false;
        }

        // --- Find connected connector + encoder + CRTC ---
        bool find_display() {
            for (int i = 0; i < m_drm_res->count_connectors; ++i) {
                drmModeConnector* c = drmModeGetConnector(m_drm_fd, m_drm_res->connectors[i]);
                if (!c) continue;
                if (c->connection == DRM_MODE_CONNECTED && c->count_modes > 0) {
                    m_connector = c;
                    break;
                }
                drmModeFreeConnector(c);
            }
            if (!m_connector) { log_err("No connected display found"); return false; }

            drmModeModeInfo* mode = pick_mode(m_connector);
            if (!mode) { log_err("No valid mode found"); return false; }
            m_mode   = *mode;
            m_width  = m_mode.hdisplay;
            m_height = m_mode.vdisplay;

            // Find encoder
            if (m_connector->encoder_id) {
                m_encoder = drmModeGetEncoder(m_drm_fd, m_connector->encoder_id);
            }
            if (!m_encoder) {
                // Try all encoders
                for (int i = 0; i < m_connector->count_encoders; ++i) {
                    drmModeEncoder* e = drmModeGetEncoder(m_drm_fd, m_connector->encoders[i]);
                    if (e && e->crtc_id) { m_encoder = e; break; }
                    if (e) drmModeFreeEncoder(e);
                }
            }
            if (!m_encoder) { log_err("No encoder found"); return false; }

            m_crtc_id    = m_encoder->crtc_id;
            m_saved_crtc = drmModeGetCrtc(m_drm_fd, m_crtc_id);

            rstd::aString modestr("Mode: ");
            modestr += m_mode.name;
            log_info(modestr.c_str());
            return true;
        }

        // --- Setup GBM surface ---
        bool setup_gbm() {
            m_gbm_dev = gbm_create_device(m_drm_fd);
            if (!m_gbm_dev) { log_err("GBM device creation failed"); return false; }

            m_gbm_surface = gbm_surface_create(
                m_gbm_dev,
                m_width, m_height,
                GBM_FORMAT_XRGB8888,
                GBM_BO_USE_SCANOUT | GBM_BO_USE_RENDERING
            );
            if (!m_gbm_surface) { log_err("GBM surface creation failed"); return false; }
            return true;
        }

        // --- Create and display a dumb buffer (immediate blue screen) ---
        bool create_dumb_buffer() {
            struct drm_mode_create_dumb create = {};
            create.width  = m_width;
            create.height = m_height;
            create.bpp    = 32;

            if (drmIoctl(m_drm_fd, DRM_IOCTL_MODE_CREATE_DUMB, &create) < 0) {
                log_err("DRM_IOCTL_MODE_CREATE_DUMB failed");
                return false;
            }

            m_dumb_handle = create.handle;
            m_dumb_size   = create.size;

            // Add framebuffer
            if (drmModeAddFB(m_drm_fd, m_width, m_height, 24, 32, create.pitch,
                             m_dumb_handle, &m_dumb_fb) != 0) {
                log_err("drmModeAddFB failed");
                return false;
            }

            // Map it
            struct drm_mode_map_dumb map = {};
            map.handle = m_dumb_handle;
            if (drmIoctl(m_drm_fd, DRM_IOCTL_MODE_MAP_DUMB, &map) < 0) {
                log_err("DRM_IOCTL_MODE_MAP_DUMB failed");
                return false;
            }

            m_dumb_map = mmap(0, m_dumb_size, PROT_READ | PROT_WRITE, MAP_SHARED,
                              m_drm_fd, map.offset);
            if (m_dumb_map == MAP_FAILED) {
                log_err("mmap dumb buffer failed");
                m_dumb_map = nullptr;
                return false;
            }

            // Fill with blue (XRGB8888: 0xFF5599DD)
            uint32_t* pixels = (uint32_t*)m_dumb_map;
            for (int i = 0; i < m_width * m_height; ++i) {
                pixels[i] = 0xFF5599DD;
            }

            // Set CRTC to display it
            if (drmModeSetCrtc(m_drm_fd, m_crtc_id, m_dumb_fb, 0, 0,
                               &m_connector->connector_id, 1, &m_mode) != 0) {
                log_err("drmModeSetCrtc failed");
                return false;
            }

            log_info("Dumb buffer displayed.");
            return true;
        }

        // --- Open evdev input devices ---
        void open_evdev() {
            m_evdev_count = 0;
            DIR* d = opendir("/dev/input");
            if (!d) return;
            struct dirent* e;
            while ((e = readdir(d)) && m_evdev_count < MAX_EVDEV) {
                // only event* devices
                const char* n = e->d_name;
                // check prefix "event" manually (no string.h)
                if (n[0]=='e' && n[1]=='v' && n[2]=='e' && n[3]=='n' && n[4]=='t') {
                    rstd::aString path("/dev/input/");
                    path += n;
                    int fd = open(path.c_str(), O_RDONLY | O_NONBLOCK | O_CLOEXEC);
                    if (fd >= 0) m_evdev_fds[m_evdev_count++] = fd;
                }
            }
            closedir(d);
        }

        // --- Setup TTY: disable echo, signals, and set graphics mode ---
        void setup_tty() {
            // Try to open the current TTY
            m_tty_fd = open("/dev/tty", O_RDWR | O_CLOEXEC);
            if (m_tty_fd < 0) {
                m_tty_fd = open("/dev/tty0", O_RDWR | O_CLOEXEC);
            }
            if (m_tty_fd < 0) {
                log_err("Could not open TTY — input might leak");
                return;
            }

            // Save original terminal state
            tcgetattr(m_tty_fd, &m_orig_termios);
            ioctl(m_tty_fd, KDGKBMODE, &m_orig_kb_mode);

            // Set raw mode: disable echo, canonical mode, signals
            struct termios raw = m_orig_termios;
            raw.c_iflag &= ~(IGNBRK | BRKINT | PARMRK | ISTRIP | INLCR | IGNCR | ICRNL | IXON);
            raw.c_oflag &= ~OPOST;
            raw.c_lflag &= ~(ECHO | ECHONL | ICANON | ISIG | IEXTEN);
            raw.c_cflag &= ~(CSIZE | PARENB);
            raw.c_cflag |= CS8;
            tcsetattr(m_tty_fd, TCSAFLUSH, &raw);

            // Set graphics mode (disable kernel keyboard processing)
            ioctl(m_tty_fd, KDSETMODE, KD_GRAPHICS);
            ioctl(m_tty_fd, KDSKBMODE, K_OFF);

            log_info("TTY set to raw mode.");
        }

        // --- Restore TTY to original state ---
        void restore_tty() {
            if (m_tty_fd < 0) return;
            ioctl(m_tty_fd, KDSKBMODE, m_orig_kb_mode);
            ioctl(m_tty_fd, KDSETMODE, KD_TEXT);
            tcsetattr(m_tty_fd, TCSAFLUSH, &m_orig_termios);
            close(m_tty_fd);
            m_tty_fd = -1;
            log_info("TTY restored.");
        }

        // --- Map evdev keycode to idk::Key ---
        idk::Key map_evdev_key(uint16_t code) {
            switch (code) {
                case 30: return idk::Key::A; case 48: return idk::Key::B; case 46: return idk::Key::C;
                case 32: return idk::Key::D; case 18: return idk::Key::E; case 33: return idk::Key::F;
                case 34: return idk::Key::G; case 35: return idk::Key::H; case 23: return idk::Key::I;
                case 36: return idk::Key::J; case 37: return idk::Key::K; case 38: return idk::Key::L;
                case 50: return idk::Key::M; case 49: return idk::Key::N; case 24: return idk::Key::O;
                case 25: return idk::Key::P; case 16: return idk::Key::Q; case 19: return idk::Key::R;
                case 31: return idk::Key::S; case 20: return idk::Key::T; case 22: return idk::Key::U;
                case 47: return idk::Key::V; case 17: return idk::Key::W; case 45: return idk::Key::X;
                case 21: return idk::Key::Y; case 44: return idk::Key::Z;
                case 11: return idk::Key::N0; case 2:  return idk::Key::N1; case 3:  return idk::Key::N2;
                case 4:  return idk::Key::N3; case 5:  return idk::Key::N4; case 6:  return idk::Key::N5;
                case 7:  return idk::Key::N6; case 8:  return idk::Key::N7; case 9:  return idk::Key::N8;
                case 10: return idk::Key::N9;
                case 1:  return idk::Key::ESCAPE;
                case 57: return idk::Key::SPACE;
                case 28: return idk::Key::ENTER;
                case 15: return idk::Key::TAB;
                case 14: return idk::Key::BACKSPACE;
                case 42: return idk::Key::LEFT_SHIFT;
                case 54: return idk::Key::RIGHT_SHIFT;
                case 29: return idk::Key::LEFT_CTRL;
                case 97: return idk::Key::RIGHT_CTRL;
                case 56: return idk::Key::LEFT_ALT;
                case 100: return idk::Key::RIGHT_ALT;
                case 125: return idk::Key::LEFT_SUPER;
                case 126: return idk::Key::RIGHT_SUPER;
                case 103: return idk::Key::UP;
                case 108: return idk::Key::DOWN;
                case 105: return idk::Key::LEFT;
                case 106: return idk::Key::RIGHT;
                default: return idk::Key::UNKNOWN;
            }
        }

        // --- Poll evdev and update input state ---
        void poll_input() {
            struct input_event ev;
            for (int i = 0; i < m_evdev_count; ++i) {
                while (true) {
                    long r = read(m_evdev_fds[i], &ev, sizeof(ev));
                    if (r < (long)sizeof(ev)) break;

                    if (ev.type == EV_KEY) {
                        if (ev.code == BTN_LEFT || ev.code == BTN_RIGHT || ev.code == BTN_MIDDLE) {
                            idk::MouseButton mb =
                                ev.code == BTN_LEFT   ? idk::MouseButton::LEFT  :
                                ev.code == BTN_RIGHT  ? idk::MouseButton::RIGHT :
                                                        idk::MouseButton::MIDDLE;
                            m_mouse_btns[(int)mb] = ev.value ?
                                idk::InputState::PRESSED : idk::InputState::RELEASED;
                        } else {
                            idk::Key k = map_evdev_key(ev.code);
                            if (k != idk::Key::UNKNOWN) {
                                if (ev.value == 0)
                                    m_keys[(int)k] = idk::InputState::RELEASED;
                                else if (ev.value == 1)
                                    m_keys[(int)k] = idk::InputState::PRESSED;
                                else if (ev.value == 2)
                                    m_keys[(int)k] = idk::InputState::REPEATED;
                            }
                            // ESC quits
                            if (ev.code == 1 && ev.value == 1) m_running = false;
                            // Super+W quits
                            if (ev.code == 17 && ev.value == 1) { // W key
                                if (m_keys[(int)idk::Key::LEFT_SUPER]  == idk::InputState::HELD ||
                                    m_keys[(int)idk::Key::RIGHT_SUPER] == idk::InputState::HELD) {
                                    m_running = false;
                                }
                            }
                            // Allow Alt+Fn for TTY switching (F1-F12: codes 59-68, 87-88)
                            if ((ev.code >= 59 && ev.code <= 68) || ev.code == 87 || ev.code == 88) {
                                if ((m_keys[(int)idk::Key::LEFT_ALT] == idk::InputState::HELD ||
                                     m_keys[(int)idk::Key::RIGHT_ALT] == idk::InputState::HELD) && m_tty_fd >= 0) {
                                    // Inject VT switch via ioctl
                                    int vt_num = (ev.code >= 59 && ev.code <= 68) ? (ev.code - 58) :
                                                 (ev.code == 87) ? 11 : 12;
                                    struct vt_stat vts;
                                    if (ioctl(m_tty_fd, VT_GETSTATE, &vts) == 0) {
                                        if (vt_num != vts.v_active) {
                                            ioctl(m_tty_fd, VT_ACTIVATE, vt_num);
                                            ioctl(m_tty_fd, VT_WAITACTIVE, vt_num);
                                        }
                                    }
                                }
                            }
                        }
                    } else if (ev.type == EV_REL) {
                        if (ev.code == REL_X) m_mouse_x += ev.value;
                        if (ev.code == REL_Y) m_mouse_y += ev.value;
                        // clamp to screen
                        if (m_mouse_x < 0) m_mouse_x = 0;
                        if (m_mouse_y < 0) m_mouse_y = 0;
                        if (m_mouse_x >= m_width)  m_mouse_x = m_width  - 1;
                        if (m_mouse_y >= m_height) m_mouse_y = m_height - 1;
                    }
                }
            }
        }

    public:
        inline kWindow_s(int /*width*/ = 0, int /*height*/ = 0) {
            // width/height come from the display mode, args ignored
            for (int i = 0; i < (int)idk::Key::COUNT; ++i)
                m_keys[i] = idk::InputState::IDLE;
            for (int i = 0; i < (int)idk::MouseButton::COUNT; ++i)
                m_mouse_btns[i] = idk::InputState::IDLE;
            for (int i = 0; i < MAX_EVDEV; ++i)
                m_evdev_fds[i] = -1;
            m_xkb_ctx = xkb_context_new(XKB_CONTEXT_NO_FLAGS);
        }

        inline void init() {
            log_info("Initializing KMS/DRM display...");
            if (!open_drm())         return;
            if (!find_display())     return;
            if (!setup_gbm())        return;
            if (!create_dumb_buffer()) return;
            open_evdev();
            setup_tty();
            log_info("KMS display ready.");
        }

        inline void run() {
            if (!m_running) return;
            poll_input();
        }

        inline void updateInputStates() {
            for (int i = 0; i < (int)idk::Key::COUNT; ++i) {
                if (m_keys[i] == idk::InputState::PRESSED)  m_keys[i] = idk::InputState::HELD;
                else if (m_keys[i] == idk::InputState::RELEASED) m_keys[i] = idk::InputState::IDLE;
            }
            for (int i = 0; i < (int)idk::MouseButton::COUNT; ++i) {
                if (m_mouse_btns[i] == idk::InputState::PRESSED)  m_mouse_btns[i] = idk::InputState::HELD;
                else if (m_mouse_btns[i] == idk::InputState::RELEASED) m_mouse_btns[i] = idk::InputState::IDLE;
            }
        }

        // --- Vulkan surface via VK_KHR_display ---
        // Call this after vkCreateInstance with VK_KHR_display extension enabled.
        // Enumerates displays, picks the first one, creates a surface directly on the hardware.
        inline VkSurfaceKHR createVulkanSurface(VkInstance instance) {
            // Find the physical device display
            uint32_t physDevCount = 0;
            vkEnumeratePhysicalDevices(instance, &physDevCount, nullptr);
            if (!physDevCount) { log_err("No Vulkan physical devices"); return VK_NULL_HANDLE; }

            VkPhysicalDevice physDevs[8] = {};
            if (physDevCount > 8) physDevCount = 8;
            vkEnumeratePhysicalDevices(instance, &physDevCount, physDevs);

            auto vkGetPhysDevDisplayProps =
                (PFN_vkGetPhysicalDeviceDisplayPropertiesKHR)
                vkGetInstanceProcAddr(instance, "vkGetPhysicalDeviceDisplayPropertiesKHR");
            auto vkGetDisplayModeProps =
                (PFN_vkGetDisplayModePropertiesKHR)
                vkGetInstanceProcAddr(instance, "vkGetDisplayModePropertiesKHR");
            auto vkGetDisplayPlaneProps =
                (PFN_vkGetPhysicalDeviceDisplayPlanePropertiesKHR)
                vkGetInstanceProcAddr(instance, "vkGetPhysicalDeviceDisplayPlanePropertiesKHR");
            auto vkGetDisplayPlaneSupportedDisplays =
                (PFN_vkGetDisplayPlaneSupportedDisplaysKHR)
                vkGetInstanceProcAddr(instance, "vkGetDisplayPlaneSupportedDisplaysKHR");
            auto vkCreateDisplayPlaneSurface =
                (PFN_vkCreateDisplayPlaneSurfaceKHR)
                vkGetInstanceProcAddr(instance, "vkCreateDisplayPlaneSurfaceKHR");

            if (!vkCreateDisplayPlaneSurface) {
                log_err("VK_KHR_display not available — did you enable the extension?");
                return VK_NULL_HANDLE;
            }

            for (uint32_t d = 0; d < physDevCount; ++d) {
                uint32_t dispCount = 0;
                vkGetPhysDevDisplayProps(physDevs[d], &dispCount, nullptr);
                if (!dispCount) continue;

                VkDisplayPropertiesKHR dispProps[4] = {};
                if (dispCount > 4) dispCount = 4;
                vkGetPhysDevDisplayProps(physDevs[d], &dispCount, dispProps);

                VkDisplayKHR display = dispProps[0].display;

                uint32_t modeCount = 0;
                vkGetDisplayModeProps(physDevs[d], display, &modeCount, nullptr);
                if (!modeCount) continue;

                VkDisplayModePropertiesKHR modeProps[16] = {};
                if (modeCount > 16) modeCount = 16;
                vkGetDisplayModeProps(physDevs[d], display, &modeCount, modeProps);

                // Pick mode matching our DRM mode
                VkDisplayModeKHR pickedMode = modeProps[0].displayMode;
                for (uint32_t m = 0; m < modeCount; ++m) {
                    auto& p = modeProps[m].parameters;
                    if ((int)p.visibleRegion.width  == m_width &&
                        (int)p.visibleRegion.height == m_height) {
                        pickedMode = modeProps[m].displayMode;
                        break;
                    }
                }

                // Find a plane that supports this display
                uint32_t planeCount = 0;
                vkGetDisplayPlaneProps(physDevs[d], &planeCount, nullptr);
                if (!planeCount) continue;

                uint32_t planeIndex = 0;
                bool     foundPlane = false;
                for (uint32_t p = 0; p < planeCount && !foundPlane; ++p) {
                    uint32_t supportedCount = 0;
                    vkGetDisplayPlaneSupportedDisplays(physDevs[d], p, &supportedCount, nullptr);
                    VkDisplayKHR supported[4] = {};
                    if (supportedCount > 4) supportedCount = 4;
                    vkGetDisplayPlaneSupportedDisplays(physDevs[d], p, &supportedCount, supported);
                    for (uint32_t s = 0; s < supportedCount; ++s) {
                        if (supported[s] == display) { planeIndex = p; foundPlane = true; break; }
                    }
                }
                if (!foundPlane) continue;

                VkDisplaySurfaceCreateInfoKHR ci = {};
                ci.sType           = VK_STRUCTURE_TYPE_DISPLAY_SURFACE_CREATE_INFO_KHR;
                ci.displayMode     = pickedMode;
                ci.planeIndex      = planeIndex;
                ci.planeStackIndex = 0;
                ci.transform       = VK_SURFACE_TRANSFORM_IDENTITY_BIT_KHR;
                ci.alphaMode       = VK_DISPLAY_PLANE_ALPHA_OPAQUE_BIT_KHR;
                ci.imageExtent     = { (uint32_t)m_width, (uint32_t)m_height };

                VkSurfaceKHR surface = VK_NULL_HANDLE;
                if (vkCreateDisplayPlaneSurface(instance, &ci, nullptr, &surface) == VK_SUCCESS) {
                    log_info("VK_KHR_display surface created.");
                    return surface;
                }
            }

            log_err("Failed to create VK_KHR_display surface");
            return VK_NULL_HANDLE;
        }

        inline gbm_device*  getGBMDevice()  { return m_gbm_dev; }
        inline gbm_surface* getGBMSurface() { return m_gbm_surface; }
        inline int          getDRMFd()      { return m_drm_fd; }
        inline uint32_t     getCRTCId()     { return m_crtc_id; }
        inline drmModeModeInfo* getMode()   { return &m_mode; }
        inline uint32_t     getConnectorId(){ return m_connector ? m_connector->connector_id : 0; }

        inline int  get_width()  const { return m_width; }
        inline int  get_height() const { return m_height; }
        inline bool isRunning()  const { return m_running; }
        inline bool WindowFocusState() const { return m_focused; }

        inline idk::InputState getKeyState(idk::Key k)         const { return m_keys[(int)k]; }
        inline idk::InputState getMouseState(idk::MouseButton b) const { return m_mouse_btns[(int)b]; }
        inline void getMousePosition(double& x, double& y)     const { x = m_mouse_x; y = m_mouse_y; }
        inline void getFramebufferMousePosition(double& x, double& y) const { x = m_mouse_x; y = m_mouse_y; }

        inline void cleanup() {
            restore_tty();
            if (m_dumb_map) {
                munmap(m_dumb_map, m_dumb_size);
                m_dumb_map = nullptr;
            }
            if (m_dumb_fb) {
                drmModeRmFB(m_drm_fd, m_dumb_fb);
                m_dumb_fb = 0;
            }
            if (m_dumb_handle) {
                struct drm_mode_destroy_dumb destroy = {};
                destroy.handle = m_dumb_handle;
                drmIoctl(m_drm_fd, DRM_IOCTL_MODE_DESTROY_DUMB, &destroy);
                m_dumb_handle = 0;
            }
            if (m_saved_crtc && m_drm_fd >= 0) {
                drmModeSetCrtc(m_drm_fd, m_saved_crtc->crtc_id,
                    m_saved_crtc->buffer_id, m_saved_crtc->x, m_saved_crtc->y,
                    &m_connector->connector_id, 1, &m_saved_crtc->mode);
                drmModeFreeCrtc(m_saved_crtc);
                m_saved_crtc = nullptr;
            }
            if (m_gbm_surface) { gbm_surface_destroy(m_gbm_surface); m_gbm_surface = nullptr; }
            if (m_gbm_dev)     { gbm_device_destroy(m_gbm_dev);     m_gbm_dev     = nullptr; }
            if (m_encoder)     { drmModeFreeEncoder(m_encoder);     m_encoder     = nullptr; }
            if (m_connector)   { drmModeFreeConnector(m_connector); m_connector   = nullptr; }
            if (m_drm_res)     { drmModeFreeResources(m_drm_res);   m_drm_res     = nullptr; }
            if (m_drm_fd >= 0) { close(m_drm_fd); m_drm_fd = -1; }
            for (int i = 0; i < m_evdev_count; ++i) close(m_evdev_fds[i]);
            if (m_xkb_state) xkb_state_unref(m_xkb_state);
            if (m_xkb_map)   xkb_keymap_unref(m_xkb_map);
            if (m_xkb_ctx)   xkb_context_unref(m_xkb_ctx);
            log_info("KMS cleanup complete.");
        }
};

#endif
