        if (arg == "--mode" || arg == "-m") {
            if (++i >= argc) { std::cerr << "--mode requires 0-14\n"; return 1; }
            startMode = std::atoi(argv[i]);
            if (startMode < 0 || startMode > 14) { std::cerr << "--mode must be 0-14\n"; return 1; }
